@{
    ViewData["Title"] = "500 - Internal Server Error";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="card p-5 text-center error-card" style="max-width: 620px; width: 100%;">
        <div class="error-code text-danger">500</div>
        <h1 class="mb-3">Internal Server Error</h1>
        <p class="text-muted mb-4">
            Възникна неочаквана грешка при обработката на заявката. Опитай отново след малко.
        </p>

        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Към началната страница</a>
            @if (User.Identity?.IsAuthenticated != true)
            {
                <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-success">Login</a>
            }
        </div>
    </div>
</div>