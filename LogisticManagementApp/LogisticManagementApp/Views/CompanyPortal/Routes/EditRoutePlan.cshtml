@model LogisticManagementApp.Models.CompanyPortal.Routes.RoutePlanEditViewModel

@{
    ViewData["Title"] = "Редакция на route plan";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Редакция на route plan</h2>

                <form asp-action="EditRoutePlan" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="RouteId" class="form-label"></label>
                            <select asp-for="RouteId"
                                    asp-items="Model.RouteOptions"
                                    class="form-select">
                                <option value="">Избери route</option>
                            </select>
                            <span asp-validation-for="RouteId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PlanDateUtc" class="form-label"></label>
                            <input asp-for="PlanDateUtc"
                                   type="datetime-local"
                                   class="form-control" />
                                   <span asp-validation-for="PlanDateUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Routes.RoutePlanStatus>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="PlanReference" class="form-label"></label>
                            <input asp-for="PlanReference"
                                   class="form-control" />
                                   <span asp-validation-for="PlanReference" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">
                            Запази
                        </button>

                        <a asp-action="RoutePlans" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}