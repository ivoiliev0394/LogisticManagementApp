@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Routes.RoutePlanStopListItemViewModel>

@{
    ViewData["Title"] = "Route Plan Stops";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Route Plan Stops</h2>
                        <p class="text-muted mb-0">
                            Планирани и реални спирания по route plans.
                        </p>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="RouteManagement" class="btn btn-outline-light">
                            Към Routes
                        </a>
                        <a asp-action="CreateRoutePlanStop" class="btn btn-primary">
                            Нов запис
                        </a>
                    </div>
                </div>

                @if (Model.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle"
                               data-table-pagination="true"
                               data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Route plan</th>
                                    <th>Location</th>
                                    <th>Seq</th>
                                    <th>Type</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.RoutePlanDisplay</div>
                                            <div class="small text-muted">
                                                @(item.RouteStopDisplay ?? "-")
                                            </div>
                                        </td>

                                        <td>@item.LocationName</td>

                                        <td>@item.SequenceNo</td>

                                        <td>@item.StopType</td>

                                        <td class="text-end">
                                            <div class="d-flex flex-wrap justify-content-end gap-2">
                                                <a asp-action="EditRoutePlanStop"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteRoutePlanStop"
                                                      asp-route-id="@item.Id"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()

                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-light">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Няма записи.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
