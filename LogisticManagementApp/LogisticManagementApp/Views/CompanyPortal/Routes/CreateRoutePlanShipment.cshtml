@model LogisticManagementApp.Models.CompanyPortal.Routes.RoutePlanShipmentCreateViewModel

@{
    ViewData["Title"] = "Нов route plan shipment";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов route plan shipment</h2>

                <form asp-action="CreateRoutePlanShipment" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="RoutePlanId" class="form-label"></label>
                            <select asp-for="RoutePlanId"
                                    asp-items="Model.RoutePlanOptions"
                                    class="form-select">
                                <option value="">Избери route plan</option>
                            </select>
                            <span asp-validation-for="RoutePlanId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ShipmentId" class="form-label"></label>
                            <select asp-for="ShipmentId"
                                    asp-items="Model.ShipmentOptions"
                                    class="form-select">
                                <option value="">Избери shipment</option>
                            </select>
                            <span asp-validation-for="ShipmentId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PickupStopId" class="form-label"></label>
                            <select asp-for="PickupStopId"
                                    asp-items="Model.RoutePlanStopOptions"
                                    class="form-select">
                                <option value="">Без pickup stop</option>
                            </select>
                            <span asp-validation-for="PickupStopId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DeliveryStopId" class="form-label"></label>
                            <select asp-for="DeliveryStopId"
                                    asp-items="Model.RoutePlanStopOptions"
                                    class="form-select">
                                <option value="">Без delivery stop</option>
                            </select>
                            <span asp-validation-for="DeliveryStopId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Priority" class="form-label"></label>
                            <input asp-for="Priority"
                                   type="number"
                                   min="1"
                                   class="form-control" />
                                   <span asp-validation-for="Priority" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">
                            Запази
                        </button>

                        <a asp-action="RoutePlanShipments" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}