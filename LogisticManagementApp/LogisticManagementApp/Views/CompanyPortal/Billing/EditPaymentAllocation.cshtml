@model LogisticManagementApp.Models.CompanyPortal.Billing.PaymentAllocationEditViewModel

@{
    ViewData["Title"] = "Редакция на payment allocation";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">

                <h2 class="h4 mb-3">Редакция на payment allocation</h2>

                <form asp-action="EditPaymentAllocation" method="post">
                    @Html.AntiForgeryToken()

                    <!-- важно за Edit -->
                    <input asp-for="Id" type="hidden" />


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="PaymentId" class="form-label"></label>
                            <select asp-for="PaymentId"
                                    asp-items="Model.PaymentOptions"
                                    class="form-select">
                                <option value="">Избери payment</option>
                            </select>
                            <span asp-validation-for="PaymentId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="InvoiceId" class="form-label"></label>
                            <select asp-for="InvoiceId"
                                    asp-items="Model.InvoiceOptions"
                                    class="form-select">
                                <option value="">Избери invoice</option>
                            </select>
                            <span asp-validation-for="InvoiceId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="AllocatedAmount" class="form-label"></label>
                            <input asp-for="AllocatedAmount" class="form-control" />
                            <span asp-validation-for="AllocatedAmount" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="AllocatedAtUtc" class="form-label"></label>
                            <input asp-for="AllocatedAtUtc"
                                   type="datetime-local"
                                   class="form-control" />
                                   <span asp-validation-for="AllocatedAtUtc" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="4"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">
                            Запази
                        </button>

                        <a asp-action="PaymentAllocations"
                               class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}