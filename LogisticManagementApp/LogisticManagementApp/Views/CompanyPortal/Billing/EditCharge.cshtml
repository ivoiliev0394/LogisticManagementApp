@model LogisticManagementApp.Models.CompanyPortal.Billing.ChargeEditViewModel
@using LogisticManagementApp.Domain.Enums.Billing

@{
    ViewData["Title"] = "Редакция на charge";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">

                <h2 class="h4 mb-3">Редакция на charge</h2>

                <form asp-action="EditCharge" method="post">
                    @Html.AntiForgeryToken()

                    <input asp-for="Id" type="hidden" />


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ShipmentId" class="form-label"></label>
                            <select asp-for="ShipmentId"
                                    asp-items="Model.ShipmentOptions"
                                    class="form-select">
                                <option value="">Избери shipment</option>
                            </select>
                            <span asp-validation-for="ShipmentId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ShipmentLegId" class="form-label"></label>
                            <select asp-for="ShipmentLegId"
                                    asp-items="Model.ShipmentLegOptions"
                                    class="form-select">
                                <option value="">Без leg</option>
                            </select>
                            <span asp-validation-for="ShipmentLegId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ChargeCode" class="form-label"></label>
                            <input asp-for="ChargeCode" class="form-control" />
                            <span asp-validation-for="ChargeCode" class="text-danger"></span>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="UnitPrice" class="form-label"></label>
                            <input asp-for="UnitPrice" class="form-control" />
                            <span asp-validation-for="UnitPrice" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Currency" class="form-label"></label>
                            <input asp-for="Currency" class="form-control" />
                            <span asp-validation-for="Currency" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="SourceType" class="form-label"></label>
                            <select asp-for="SourceType"
                                    asp-items="Html.GetEnumSelectList<ChargeSourceType>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="SourceType" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TaxRatePercent" class="form-label"></label>
                            <input asp-for="TaxRatePercent" class="form-control" />
                            <span asp-validation-for="TaxRatePercent" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="4"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="IsTaxable" class="form-check-input" />
                                <span asp-validation-for="IsTaxable" class="text-danger"></span>
                                <label asp-for="IsTaxable" class="form-check-label">
                                    Taxable
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">
                            Запази
                        </button>

                        <a asp-action="Charges" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}