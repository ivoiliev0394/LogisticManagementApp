@model LogisticManagementApp.Models.CompanyPortal.Billing.InvoiceEditViewModel
@using LogisticManagementApp.Domain.Enums.Billing

@{
    ViewData["Title"] = "Редакция на invoice";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">

                <h2 class="h4 mb-3">Редакция на invoice</h2>

                <form asp-action="EditInvoice" method="post">
                    @Html.AntiForgeryToken()

                    <input asp-for="Id" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="InvoiceNo" class="form-label"></label>
                            <input asp-for="InvoiceNo" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status"
                                    asp-items="Html.GetEnumSelectList<InvoiceStatus>()"
                                    class="form-select">
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="IssueDateUtc" class="form-label"></label>
                            <input asp-for="IssueDateUtc"
                                   type="date"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DueDateUtc" class="form-label"></label>
                            <input asp-for="DueDateUtc"
                                   type="date"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Currency" class="form-label"></label>
                            <input asp-for="Currency" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="SubtotalAmount" class="form-label"></label>
                            <input asp-for="SubtotalAmount" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="TaxAmount" class="form-label"></label>
                            <input asp-for="TaxAmount" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="TotalAmount" class="form-label"></label>
                            <input asp-for="TotalAmount" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="4"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">
                            Запази
                        </button>

                        <a asp-action="Invoices" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}