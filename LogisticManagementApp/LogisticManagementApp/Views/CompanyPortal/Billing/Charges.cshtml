@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Billing.ChargeListItemViewModel>

@{
    ViewData["Title"] = "Charges";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">

                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Charges</h2>
                        <p class="text-muted mb-0">
                            Такси и начисления за shipments на текущата компания.
                        </p>
                    </div>

                    <a asp-action="CreateCharge" class="btn btn-success">
                        Нов charge
                    </a>
                </div>
@if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">
                        Няма налични записи.
                    </div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0"
                               data-table-pagination="true"
                               data-page-size="10">

                            <thead>
                                <tr>
                                    <th>Shipment</th>
                                    <th>Code</th>
                                    <th>Description</th>
                                    <th>Qty</th>
                                    <th>Unit price</th>
                                    <th>Currency</th>
                                    <th>Source</th>
                                    <th>Taxable</th>
                                    <th>Tax %</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">
                                            @item.ShipmentNo
                                        </td>

                                        <td>
                                            @item.ChargeCode
                                        </td>

                                        <td>
                                            @item.Description
                                        </td>

                                        <td>
                                            @item.Quantity
                                        </td>

                                        <td>
                                            @item.UnitPrice.ToString("F2")
                                        </td>

                                        <td>
                                            @item.Currency
                                        </td>

                                        <td>
                                            @item.SourceType
                                        </td>

                                        <td>
                                            @(item.IsTaxable ? "Да" : "Не")
                                        </td>

                                        <td>
                                            @(item.TaxRatePercent?.ToString("F2") ?? "-")
                                        </td>

                                        <td class="text-end">
                                            <div class="d-flex gap-2 justify-content-end">
                                                <a asp-action="EditCharge"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteCharge"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden"
                                                           name="id"
                                                           value="@item.Id" />

                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-danger">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
