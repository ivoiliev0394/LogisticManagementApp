@model LogisticManagementApp.Models.CompanyPortal.Billing.PaymentCreateViewModel
@using LogisticManagementApp.Domain.Enums.Billing

@{
    ViewData["Title"] = "Ново payment";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">

                <h2 class="h4 mb-3">Ново payment</h2>

                <form asp-action="CreatePayment" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="InvoiceId" class="form-label"></label>
                            <select asp-for="InvoiceId"
                                    asp-items="Model.InvoiceOptions"
                                    class="form-select">
                                <option value="">Избери invoice</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PaymentMethod" class="form-label"></label>
                            <select asp-for="PaymentMethod"
                                    asp-items="Html.GetEnumSelectList<PaymentMethod>()"
                                    class="form-select">
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="PaymentDateUtc" class="form-label"></label>
                            <input asp-for="PaymentDateUtc"
                                   type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Amount" class="form-label"></label>
                            <input asp-for="Amount" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Currency" class="form-label"></label>
                            <input asp-for="Currency" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status"
                                    asp-items="Html.GetEnumSelectList<PaymentStatus>()"
                                    class="form-select">
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TransactionReference" class="form-label"></label>
                            <input asp-for="TransactionReference" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="4"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">
                            Запази
                        </button>

                        <a asp-action="Payments" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}