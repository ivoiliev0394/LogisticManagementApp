@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Billing.ChargeRuleAppliedListItemViewModel>

@{
    ViewData["Title"] = "Charge Rules Applied";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">

                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Charge Rules Applied</h2>
                        <p class="text-muted mb-0">
                            Правила, приложени върху company charges.
                        </p>
                    </div>

                    <a asp-action="CreateChargeRuleApplied" class="btn btn-success">
                        Ново правило
                    </a>
                </div>

                <partial name="_StatusMessage" />

                @if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">
                        Няма налични записи.
                    </div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0"
                               data-table-pagination="true"
                               data-page-size="10">

                            <thead>
                                <tr>
                                    <th>Shipment</th>
                                    <th>Charge</th>
                                    <th>Source type</th>
                                    <th>Rule code</th>
                                    <th>Description</th>
                                    <th>Amount</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            @item.ShipmentNo
                                        </td>

                                        <td class="fw-semibold">
                                            @item.ChargeCode
                                        </td>

                                        <td>
                                            @(item.SourceEntityType ?? "-")
                                        </td>

                                        <td>
                                            @(item.RuleCode ?? "-")
                                        </td>

                                        <td>
                                            @(item.RuleDescription ?? "-")
                                        </td>

                                        <td>
                                            @(item.AppliedAmount?.ToString("F2") ?? "-")
                                        </td>

                                        <td class="text-end">
                                            <div class="d-flex gap-2 justify-content-end">
                                                <a asp-action="EditChargeRuleApplied"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteChargeRuleApplied"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden"
                                                           name="id"
                                                           value="@item.Id" />

                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-danger">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                    </div>
                }

            </div>
        </div>
    </div>
</div>