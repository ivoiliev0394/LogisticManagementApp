@model LogisticManagementApp.Models.CompanyPortal.Orders.CompanyOrderEditViewModel
@using LogisticManagementApp.Domain.Enums.Orders

@{
    ViewData["Title"] = "Редакция на поръчка";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h2 class="h4 mb-1">Редакция на поръчка</h2>
                    <p class="text-muted mb-0">@Model.OrderNo | @Model.Status</p>
                </div>

                <form asp-action="EditOrder" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="OrderNo" class="form-label"></label>
                            <input asp-for="OrderNo" class="form-control" />
                            <span asp-validation-for="OrderNo" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="PickupAddressId" class="form-label"></label>
                            <select asp-for="PickupAddressId" asp-items="Model.AddressOptions" class="form-select">
                                <option value="">Изберете pickup адрес</option>
                            </select>
                            <span asp-validation-for="PickupAddressId" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="DeliveryAddressId" class="form-label"></label>
                            <select asp-for="DeliveryAddressId" asp-items="Model.AddressOptions" class="form-select">
                                <option value="">Изберете delivery адрес</option>
                            </select>
                            <span asp-validation-for="DeliveryAddressId" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Priority" class="form-label"></label>
                            <select asp-for="Priority" class="form-select"
                                    asp-items="Html.GetEnumSelectList<OrderPriority>()"></select>
                                    <span asp-validation-for="Priority" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="RequestedPickupDateUtc" class="form-label"></label>
                            <input asp-for="RequestedPickupDateUtc" type="datetime-local" class="form-control" />
                            <span asp-validation-for="RequestedPickupDateUtc" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="CustomerReference" class="form-label"></label>
                            <input asp-for="CustomerReference" class="form-control" />
                            <span asp-validation-for="CustomerReference" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-primary">Запази</button>
                        <a asp-action="OrderDetails" asp-route-id="@Model.Id" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
