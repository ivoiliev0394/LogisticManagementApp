@model LogisticManagementApp.Models.CompanyPortal.Orders.CompanyOrderLineEditViewModel

@{
    ViewData["Title"] = "Редакция на ред";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h2 class="h4 mb-1">Редакция на order line</h2>
                    <p class="text-muted mb-0">Променете данните на реда.</p>
                </div>

                <form asp-action="EditOrderLine" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="OrderId" type="hidden" />

                    <div class="row g-3">
                        <div class="col-12 col-md-3">
                            <label asp-for="LineNo" class="form-label"></label>
                            <input asp-for="LineNo" class="form-control" />
                            <span asp-validation-for="LineNo" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-9">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-3">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-3">
                            <label asp-for="QuantityUnit" class="form-label"></label>
                            <input asp-for="QuantityUnit" class="form-control" />
                            <span asp-validation-for="QuantityUnit" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-3">
                            <label asp-for="GrossWeightKg" class="form-label"></label>
                            <input asp-for="GrossWeightKg" class="form-control" />
                            <span asp-validation-for="GrossWeightKg" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-3">
                            <label asp-for="VolumeCbm" class="form-label"></label>
                            <input asp-for="VolumeCbm" class="form-control" />
                            <span asp-validation-for="VolumeCbm" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="HsCode" class="form-label"></label>
                            <input asp-for="HsCode" class="form-control" />
                            <span asp-validation-for="HsCode" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="OriginCountry" class="form-label"></label>
                            <input asp-for="OriginCountry" class="form-control" />
                            <span asp-validation-for="OriginCountry" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check mt-2">
                                <input asp-for="IsDangerousGoods" class="form-check-input" />
                                <span asp-validation-for="IsDangerousGoods" class="text-danger"></span>
                                <label asp-for="IsDangerousGoods" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-primary">Запази</button>
                        <a asp-action="OrderDetails" asp-route-id="@Model.OrderId" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
