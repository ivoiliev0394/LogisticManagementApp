@model LogisticManagementApp.Models.CompanyPortal.Orders.CompanyOrdersViewModel

@{
    ViewData["Title"] = "Поръчки";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <span class="badge bg-success mb-2">Orders</span>
                        <h2 class="h4 mb-1">Моите поръчки</h2>
                        <p class="text-muted mb-0">Преглед и управление на поръчките на компанията.</p>
                    </div>

                    <a asp-action="CreateOrder" class="btn btn-primary">
                        Нова поръчка
                    </a>
                </div>
@if (Model.Orders.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table table-hover align-middle" data-table-pagination="true" data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Номер</th>
                                    <th>Статус</th>
                                    <th>Приоритет</th>
                                    <th>Pickup</th>
                                    <th>Delivery</th>
                                    <th>Линии</th>
                                    <th>Pickup дата</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.Orders)
                                {
                                    <tr>
                                        <td class="fw-semibold">@order.OrderNo</td>
                                        <td>@order.Status</td>
                                        <td>@order.Priority</td>
                                        <td>@(order.PickupAddress ?? "-")</td>
                                        <td>@(order.DeliveryAddress ?? "-")</td>
                                        <td>@order.LinesCount</td>
                                        <td>@(order.RequestedPickupDateUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                        <td class="text-end">
                                            <a asp-action="OrderDetails"
                                                   asp-route-id="@order.Id"
                                                   class="btn btn-sm btn-outline-success">
                                                More details
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="stat-card">
                        <div class="fw-semibold mb-1">Няма налични поръчки</div>
                        <div class="text-muted">Все още няма създадени поръчки за тази компания.</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>