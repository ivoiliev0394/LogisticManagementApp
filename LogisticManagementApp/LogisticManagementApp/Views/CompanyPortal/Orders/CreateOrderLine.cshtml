@model LogisticManagementApp.Models.CompanyPortal.Orders.CompanyOrderLineCreateViewModel

@{
    ViewData["Title"] = "Добавяне на ред";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h2 class="h4 mb-1">Добавяне на order line</h2>
                    <p class="text-muted mb-0">Добавете ред към избраната поръчка.</p>
                </div>

                <form asp-action="CreateOrderLine" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="OrderId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-12 col-md-3">
                            <label asp-for="LineNo" class="form-label"></label>
                            <input asp-for="LineNo" class="form-control" />
                        </div>

                        <div class="col-12 col-md-9">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" />
                        </div>

                        <div class="col-12 col-md-3">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" />
                        </div>

                        <div class="col-12 col-md-3">
                            <label asp-for="QuantityUnit" class="form-label"></label>
                            <input asp-for="QuantityUnit" class="form-control" />
                        </div>

                        <div class="col-12 col-md-3">
                            <label asp-for="GrossWeightKg" class="form-label"></label>
                            <input asp-for="GrossWeightKg" class="form-control" />
                        </div>

                        <div class="col-12 col-md-3">
                            <label asp-for="VolumeCbm" class="form-label"></label>
                            <input asp-for="VolumeCbm" class="form-control" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="HsCode" class="form-label"></label>
                            <input asp-for="HsCode" class="form-control" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="OriginCountry" class="form-label"></label>
                            <input asp-for="OriginCountry" class="form-control" />
                        </div>

                        <div class="col-12">
                            <div class="form-check mt-2">
                                <input asp-for="IsDangerousGoods" class="form-check-input" />
                                <label asp-for="IsDangerousGoods" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-primary">Добави</button>
                        <a asp-action="OrderDetails" asp-route-id="@Model.OrderId" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>