@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Pricing.TariffSurchargeListItemViewModel>

@{
    ViewData["Title"] = "Tariff Surcharges";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Tariff Surcharges</h2>
                        <p class="text-muted mb-0">
                            Връзки между тарифи и допълнителни такси.
                        </p>
                    </div>
                </div>

                <partial name="_StatusMessage" />

                @if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">
                        Няма налични записи.
                    </div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0"
                               data-table-pagination="true"
                               data-page-size="10">
                            <thead>
                                <tr>
                                    <th>Service Level</th>
                                    <th>Geo Zone</th>
                                    <th>Surcharge</th>
                                    <th>Apply as</th>
                                    <th>Value</th>
                                    <th>Min</th>
                                    <th>Max</th>
                                    <th>Active</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">
                                            @item.ServiceLevelCode
                                        </td>

                                        <td>@item.GeoZoneCode</td>

                                        <td>@item.SurchargeCode</td>

                                        <td>@item.ApplyAs</td>

                                        <td>
                                            @item.Value.ToString("0.00")
                                        </td>

                                        <td>
                                            @(item.MinAmount?.ToString("0.00") ?? "-")
                                        </td>

                                        <td>
                                            @(item.MaxAmount?.ToString("0.00") ?? "-")
                                        </td>

                                        <td>
                                            @(item.IsActive ? "Да" : "Не")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>