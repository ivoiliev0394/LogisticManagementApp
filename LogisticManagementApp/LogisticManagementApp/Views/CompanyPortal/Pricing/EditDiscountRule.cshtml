@model LogisticManagementApp.Models.CompanyPortal.Pricing.DiscountRuleEditViewModel
@using LogisticManagementApp.Domain.Enums.Pricing

@{
    ViewData["Title"] = "Редакция на discount rule";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Редакция на discount rule</h2>

                <form asp-action="EditDiscountRule" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />


                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="AgreementId" class="form-label">Agreement</label>
                            <select asp-for="AgreementId"
                                    asp-items="Model.AgreementOptions"
                                    class="form-select">
                                <option value="">-- Избери --</option>
                            </select>
                            <span asp-validation-for="AgreementId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ServiceLevelId" class="form-label">Service Level</label>
                            <select asp-for="ServiceLevelId"
                                    asp-items="Model.ServiceLevelOptions"
                                    class="form-select">
                                <option value="">-- Няма --</option>
                            </select>
                            <span asp-validation-for="ServiceLevelId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="GeoZoneId" class="form-label">Geo Zone</label>
                            <select asp-for="GeoZoneId"
                                    asp-items="Model.GeoZoneOptions"
                                    class="form-select">
                                <option value="">-- Няма --</option>
                            </select>
                            <span asp-validation-for="GeoZoneId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DiscountType" class="form-label"></label>
                            <select asp-for="DiscountType"
                                    asp-items="Html.GetEnumSelectList<DiscountType>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="DiscountType" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Value" class="form-label"></label>
                            <input asp-for="Value"
                                   type="number"
                                   step="0.01"
                                   class="form-control" />
                                   <span asp-validation-for="Value" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="MinShipmentValue" class="form-label"></label>
                            <input asp-for="MinShipmentValue"
                                   type="number"
                                   step="0.01"
                                   class="form-control" />
                                   <span asp-validation-for="MinShipmentValue" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="MaxShipmentValue" class="form-label"></label>
                            <input asp-for="MaxShipmentValue"
                                   type="number"
                                   step="0.01"
                                   class="form-control" />
                                   <span asp-validation-for="MaxShipmentValue" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ValidFromUtc" class="form-label"></label>
                            <input asp-for="ValidFromUtc"
                                   type="date"
                                   class="form-control" />
                                   <span asp-validation-for="ValidFromUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ValidToUtc" class="form-label"></label>
                            <input asp-for="ValidToUtc"
                                   type="date"
                                   class="form-control" />
                                   <span asp-validation-for="ValidToUtc" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="4"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive"
                                       class="form-check-input" />
                                       <span asp-validation-for="IsActive" class="text-danger"></span>
                                <label asp-for="IsActive"
                                       class="form-check-label">
                                    Активен
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">
                            Запази
                        </button>

                        <a asp-action="DiscountRules" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}