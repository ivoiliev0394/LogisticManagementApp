@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Pricing.AgreementListItemViewModel>

@{
    ViewData["Title"] = "Agreements";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Agreements</h2>
                        <p class="text-muted mb-0">
                            Договори, свързани с текущата компания.
                        </p>
                    </div>

                    <a asp-action="CreateAgreement" class="btn btn-success">
                        Нов agreement
                    </a>
                </div>
@if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">
                        Няма налични записи.
                    </div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0"
                               data-table-pagination="true"
                               data-page-size="10">
                            <thead>
                                <tr>
                                    <th>Number</th>
                                    <th>Type</th>
                                    <th>Valid from</th>
                                    <th>Valid to</th>
                                    <th>Currency</th>
                                    <th>Payment terms</th>
                                    <th>Active</th>
                                    <th>Notes</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">
                                            @item.AgreementNumber
                                        </td>

                                        <td>@item.AgreementType</td>

                                        <td>
                                            @item.ValidFromUtc.ToString("dd.MM.yyyy")
                                        </td>

                                        <td>
                                            @(item.ValidToUtc?.ToString("dd.MM.yyyy") ?? "-")
                                        </td>

                                        <td>@item.Currency</td>

                                        <td>
                                            @(item.PaymentTerms ?? "-")
                                        </td>

                                        <td>
                                            @(item.IsActive ? "Да" : "Не")
                                        </td>

                                        <td>
                                            @(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)
                                        </td>

                                        <td class="text-end">
                                            <div class="d-flex gap-2 justify-content-end">
                                                <a asp-action="EditAgreement"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteAgreement"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />

                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-danger">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
