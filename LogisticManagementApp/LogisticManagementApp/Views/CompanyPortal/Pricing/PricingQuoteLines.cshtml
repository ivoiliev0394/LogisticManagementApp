@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Pricing.PricingQuoteLineListItemViewModel>

@{
    ViewData["Title"] = "Pricing Quote Lines";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Pricing Quote Lines</h2>
                        <p class="text-muted mb-0">
                            Редове към офертите за текущата компания.
                        </p>
                    </div>

                    <a asp-action="CreatePricingQuoteLine" class="btn btn-success">
                        Нов pricing quote line
                    </a>
                </div>

                <partial name="_StatusMessage" />

                @if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">
                        Няма налични записи.
                    </div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0"
                               data-table-pagination="true"
                               data-page-size="10">
                            <thead>
                                <tr>
                                    <th>Quote</th>
                                    <th>Line</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th>Qty</th>
                                    <th>Unit price</th>
                                    <th>Amount</th>
                                    <th>Reference</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">
                                            @item.QuoteNumber
                                        </td>

                                        <td>@item.LineNo</td>

                                        <td>@item.LineType</td>

                                        <td>@item.Description</td>

                                        <td>
                                            @item.Quantity.ToString("0.##")
                                        </td>

                                        <td>
                                            @item.UnitPrice.ToString("0.00")
                                        </td>

                                        <td>
                                            @item.LineAmount.ToString("0.00")
                                        </td>

                                        <td>
                                            @(item.ReferenceCode ?? "-")
                                        </td>

                                        <td class="text-end">
                                            <div class="d-flex gap-2 justify-content-end">
                                                <a asp-action="EditPricingQuoteLine"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeletePricingQuoteLine"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />

                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-danger">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>