@model LogisticManagementApp.Models.CompanyPortal.Pricing.PricingQuoteLineEditViewModel
@using LogisticManagementApp.Domain.Enums.Pricing

@{
    ViewData["Title"] = "Редакция на pricing quote line";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Редакция на pricing quote line</h2>

                <form asp-action="EditPricingQuoteLine" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="PricingQuoteId" class="form-label">Pricing Quote</label>
                            <select asp-for="PricingQuoteId"
                                    asp-items="Model.PricingQuoteOptions"
                                    class="form-select">
                                <option value="">-- Избери --</option>
                            </select>
                            <span asp-validation-for="PricingQuoteId" class="text-danger"></span>
                        </div>

                        <div class="col-md-2">
                            <label asp-for="LineNo" class="form-label"></label>
                            <input asp-for="LineNo"
                                   type="number"
                                   class="form-control" />
                                   <span asp-validation-for="LineNo" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="LineType" class="form-label"></label>
                            <select asp-for="LineType"
                                    asp-items="Html.GetEnumSelectList<PricingQuoteLineType>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="LineType" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="ReferenceCode" class="form-label"></label>
                            <input asp-for="ReferenceCode"
                                   class="form-control" />
                                   <span asp-validation-for="ReferenceCode" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description"
                                   class="form-control" />
                                   <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity"
                                   type="number"
                                   step="0.01"
                                   class="form-control" />
                                   <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="UnitPrice" class="form-label"></label>
                            <input asp-for="UnitPrice"
                                   type="number"
                                   step="0.01"
                                   class="form-control" />
                                   <span asp-validation-for="UnitPrice" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="LineAmount" class="form-label"></label>
                            <input asp-for="LineAmount"
                                   type="number"
                                   step="0.01"
                                   class="form-control" />
                                   <span asp-validation-for="LineAmount" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="4"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">
                            Запази
                        </button>

                        <a asp-action="PricingQuoteLines" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}