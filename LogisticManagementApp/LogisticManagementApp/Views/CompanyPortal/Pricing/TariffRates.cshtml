@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Pricing.TariffRateListItemViewModel>

@{
    ViewData["Title"] = "Tariff Rates";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Tariff Rates</h2>
                        <p class="text-muted mb-0">
                            Стъпките и цените към всяка тарифа.
                        </p>
                    </div>
                </div>
@if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">
                        Няма налични записи.
                    </div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0"
                               data-table-pagination="true"
                               data-page-size="10">
                            <thead>
                                <tr>
                                    <th>Service Level</th>
                                    <th>Geo Zone</th>
                                    <th>From</th>
                                    <th>To</th>
                                    <th>Price</th>
                                    <th>Min charge</th>
                                    <th>Step</th>
                                    <th>Sort</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">
                                            @item.ServiceLevelCode
                                        </td>

                                        <td>@item.GeoZoneCode</td>

                                        <td>
                                            @item.FromValue.ToString("0.##")
                                        </td>

                                        <td>
                                            @(item.ToValue?.ToString("0.##") ?? "-")
                                        </td>

                                        <td>
                                            @item.Price.ToString("0.00")
                                        </td>

                                        <td>
                                            @(item.MinCharge?.ToString("0.00") ?? "-")
                                        </td>

                                        <td>
                                            @(item.StepValue?.ToString("0.##") ?? "-")
                                        </td>

                                        <td>@item.SortOrder</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>