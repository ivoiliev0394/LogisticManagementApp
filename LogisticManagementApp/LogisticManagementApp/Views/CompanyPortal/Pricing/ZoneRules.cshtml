@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Pricing.ZoneRuleListItemViewModel>

@{
    ViewData["Title"] = "Zone Rules";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Zone Rules</h2>
                        <p class="text-muted mb-0">
                            Правила за принадлежност към зони според държава, град и пощенски код.
                        </p>
                    </div>
                </div>
@if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">
                        Няма налични записи.
                    </div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0"
                               data-table-pagination="true"
                               data-page-size="10">
                            <thead>
                                <tr>
                                    <th>Zone</th>
                                    <th>Name</th>
                                    <th>Country</th>
                                    <th>City</th>
                                    <th>Postal from</th>
                                    <th>Postal to</th>
                                    <th>Priority</th>
                                    <th>Valid</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">
                                            @item.GeoZoneCode
                                        </td>

                                        <td>@item.GeoZoneName</td>

                                        <td>@(item.Country ?? "-")</td>

                                        <td>@(item.City ?? "-")</td>

                                        <td>@(item.PostalCodeFrom ?? "-")</td>

                                        <td>@(item.PostalCodeTo ?? "-")</td>

                                        <td>@item.Priority</td>

                                        <td>
                                            @(item.ValidFromUtc?.ToString("dd.MM.yyyy") ?? "-")
                                            -
                                            @(item.ValidToUtc?.ToString("dd.MM.yyyy") ?? "-")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>