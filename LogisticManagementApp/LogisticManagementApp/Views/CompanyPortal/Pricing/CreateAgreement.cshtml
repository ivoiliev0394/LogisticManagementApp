@model LogisticManagementApp.Models.CompanyPortal.Pricing.AgreementCreateViewModel
@using LogisticManagementApp.Domain.Enums.Pricing

@{
    ViewData["Title"] = "Нов agreement";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов agreement</h2>

                <form asp-action="CreateAgreement" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="AgreementNumber" class="form-label"></label>
                            <input asp-for="AgreementNumber" class="form-control" />
                            <span asp-validation-for="AgreementNumber" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="AgreementType" class="form-label"></label>
                            <select asp-for="AgreementType"
                                    asp-items="Html.GetEnumSelectList<AgreementType>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="AgreementType" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ValidFromUtc" class="form-label"></label>
                            <input asp-for="ValidFromUtc"
                                   type="date"
                                   class="form-control" />
                                   <span asp-validation-for="ValidFromUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ValidToUtc" class="form-label"></label>
                            <input asp-for="ValidToUtc"
                                   type="date"
                                   class="form-control" />
                                   <span asp-validation-for="ValidToUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Currency" class="form-label"></label>
                            <input asp-for="Currency"
                                   class="form-control" />
                                   <span asp-validation-for="Currency" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PaymentTerms" class="form-label"></label>
                            <input asp-for="PaymentTerms"
                                   class="form-control" />
                                   <span asp-validation-for="PaymentTerms" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="4"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive"
                                       class="form-check-input" />
                                       <span asp-validation-for="IsActive" class="text-danger"></span>
                                <label asp-for="IsActive"
                                       class="form-check-label">
                                    Активен
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">
                            Запази
                        </button>

                        <a asp-action="Agreements" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}