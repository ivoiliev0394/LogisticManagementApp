@model LogisticManagementApp.Models.CompanyPortal.Shipments.References.CompanyShipmentReferenceEditViewModel
@using LogisticManagementApp.Domain.Enums.Shipments

@{
    ViewData["Title"] = "Редакция на Shipment Reference";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h2 class="h4 mb-1">Редакция на Shipment Reference</h2>
                    <p class="text-muted mb-0">@Model.ShipmentNo</p>
                </div>

                <form asp-action="EditShipmentReference" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="ShipmentId" type="hidden" />


                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="ReferenceType" class="form-label"></label>
                            <select asp-for="ReferenceType" class="form-select"
                                    asp-items="Html.GetEnumSelectList<ShipmentReferenceType>()"></select>
                                    <span asp-validation-for="ReferenceType" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="ReferenceValue" class="form-label"></label>
                            <input asp-for="ReferenceValue" class="form-control" />
                            <span asp-validation-for="ReferenceValue" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-primary">Запази</button>
                        <a asp-action="ShipmentReferences"
                               asp-route-shipmentId="@Model.ShipmentId"
                               class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
