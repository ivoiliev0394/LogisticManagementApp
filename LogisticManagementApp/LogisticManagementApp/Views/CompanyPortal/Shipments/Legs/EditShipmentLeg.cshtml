@model LogisticManagementApp.Models.CompanyPortal.Shipments.Legs.CompanyShipmentLegEditViewModel
@using LogisticManagementApp.Domain.Enums.Shipments

@{
    ViewData["Title"] = "Редакция на Shipment Leg";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h2 class="h4 mb-1">Редакция на Shipment Leg</h2>
                    <p class="text-muted mb-0">@Model.ShipmentNo | Current status: @Model.CurrentStatus</p>
                </div>

                <form asp-action="EditShipmentLeg" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="ShipmentId" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <label asp-for="LegNo" class="form-label"></label>
                            <input asp-for="LegNo" class="form-control" />
                        </div>

                        <div class="col-12 col-md-4">
                            <label asp-for="Mode" class="form-label"></label>
                            <select asp-for="Mode" asp-items="Html.GetEnumSelectList<TransportMode>()" class="form-select"></select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="OriginLocationId" class="form-label"></label>
                            <select asp-for="OriginLocationId" asp-items="Model.LocationOptions" class="form-select">
                                <option value="">Изберете origin location</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="DestinationLocationId" class="form-label"></label>
                            <select asp-for="DestinationLocationId" asp-items="Model.LocationOptions" class="form-select">
                                <option value="">Изберете destination location</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="ETD_Utc" class="form-label"></label>
                            <input asp-for="ETD_Utc" class="form-control" type="datetime-local" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="ETA_Utc" class="form-label"></label>
                            <input asp-for="ETA_Utc" class="form-control" type="datetime-local" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="ATD_Utc" class="form-label"></label>
                            <input asp-for="ATD_Utc" class="form-control" type="datetime-local" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="ATA_Utc" class="form-label"></label>
                            <input asp-for="ATA_Utc" class="form-control" type="datetime-local" />
                        </div>

                        <div class="col-12">
                            <label asp-for="CarrierReference" class="form-label"></label>
                            <input asp-for="CarrierReference" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-primary">Запази</button>
                        <a asp-action="ShipmentLegDetails"
                               asp-route-id="@Model.Id"
                               class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>