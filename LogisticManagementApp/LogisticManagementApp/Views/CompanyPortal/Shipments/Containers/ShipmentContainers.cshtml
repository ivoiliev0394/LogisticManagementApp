@model LogisticManagementApp.Models.CompanyPortal.Shipments.Containers.CompanyShipmentContainersViewModel

@{
    ViewData["Title"] = "Shipment Containers";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Shipment Containers</h2>
                        <p class="text-muted mb-0">@Model.ShipmentNo</p>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.CanManageContainers)
                        {
                            <a asp-action="CreateShipmentContainer"
                                   asp-route-shipmentId="@Model.ShipmentId"
                                   class="btn btn-primary">
                                Добави container
                            </a>
                        }

                        <a asp-action="ShipmentDetails"
                               asp-route-id="@Model.ShipmentId"
                               class="btn btn-outline-light">
                            Назад към shipment
                        </a>
                    </div>
                </div>

                @if (Model.Containers.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle" data-table-pagination="true" data-page-size="8">
                            <thead>
                                <tr>
                                    <th>Container</th>
                                    <th>Shipment Leg</th>
                                    <th>Gross Weight</th>
                                    <th>Seal Number</th>
                                    <th>Notes</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Containers)
                                {
                                    <tr>
                                        <td>@item.ContainerDisplay</td>
                                        <td>@(item.ShipmentLegDisplay ?? "-")</td>
                                        <td>@(item.GrossWeightKg?.ToString("0.##") ?? "-")</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.SealNumber) ? "-" : item.SealNumber)</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)</td>
                                        <td class="text-end">
                                            @if (Model.CanManageContainers)
                                            {
                                                <div class="d-flex justify-content-end flex-wrap gap-2">
                                                    <a asp-action="EditShipmentContainer"
                                                           asp-route-id="@item.Id"
                                                           class="btn btn-sm btn-outline-light">
                                                        Редакция
                                                    </a>

                                                    <form asp-action="DeleteShipmentContainer"
                                                          asp-route-id="@item.Id"
                                                          asp-route-shipmentId="@Model.ShipmentId"
                                                          method="post"
                                                          onsubmit="return confirm('Сигурен ли си, че искаш да изтриеш този shipment container?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-light">
                                                            Изтрий
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Read only</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Няма containers за този shipment.</div>
                }
            </div>
        </div>
    </div>
</div>