@model LogisticManagementApp.Models.CompanyPortal.Shipments.Ulds.CompanyShipmentUldEditViewModel

@{
    ViewData["Title"] = "Редакция на Shipment ULD";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h2 class="h4 mb-1">Редакция на Shipment ULD</h2>
                    <p class="text-muted mb-0">@Model.ShipmentNo</p>
                </div>

                <form asp-action="EditShipmentUld" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="ShipmentId" type="hidden" />


                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="UldId" class="form-label"></label>
                            <select asp-for="UldId" class="form-select">
                                <option value="">-- Избери ULD --</option>
                                @foreach (var option in Model.UldOptions)
                                {
                                    <option value="@option.Id" selected="@(option.Id == Model.UldId ? "selected" : null)">
                                        @option.DisplayName
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="UldId" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="ShipmentLegId" class="form-label"></label>
                            <select asp-for="ShipmentLegId" class="form-select">
                                <option value="">-- Без leg --</option>
                                @foreach (var option in Model.ShipmentLegOptions)
                                {
                                    <option value="@option.Id" selected="@(Model.ShipmentLegId == option.Id ? "selected" : null)">
                                        @option.DisplayName
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="ShipmentLegId" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="GrossWeightKg" class="form-label"></label>
                            <input asp-for="GrossWeightKg" class="form-control" />
                            <span asp-validation-for="GrossWeightKg" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="VolumeCbm" class="form-label"></label>
                            <input asp-for="VolumeCbm" class="form-control" />
                            <span asp-validation-for="VolumeCbm" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-primary">Запази</button>
                        <a asp-action="ShipmentUlds"
                               asp-route-shipmentId="@Model.ShipmentId"
                               class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
