@model LogisticManagementApp.Models.CompanyPortal.Shipments.ProofOfDelivery.CompanyProofOfDeliveriesViewModel

@{
    ViewData["Title"] = "Proof Of Deliveries";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Proof Of Deliveries</h2>
                        <p class="text-muted mb-0">@Model.ShipmentNo</p>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.CanCreateProofOfDelivery)
                        {
                            <a asp-action="CreateProofOfDelivery"
                                   asp-route-shipmentId="@Model.ShipmentId"
                                   class="btn btn-primary">
                                Добави POD
                            </a>
                        }

                        <a asp-action="ShipmentDetails"
                               asp-route-id="@Model.ShipmentId"
                               class="btn btn-outline-light">
                            Назад към shipment
                        </a>
                    </div>
                </div>

                @if (Model.ProofOfDeliveries.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle" data-table-pagination="true" data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Delivered At UTC</th>
                                    <th>Receiver</th>
                                    <th>Signature File</th>
                                    <th>Notes</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ProofOfDeliveries)
                                {
                                    <tr>
                                        <td>@item.DeliveredAtUtc.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.ReceiverName) ? "-" : item.ReceiverName)</td>
                                        <td>@(item.SignatureFileResourceId?.ToString() ?? "-")</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)</td>
                                        <td class="text-end">
                                            @if (Model.CanManageProofOfDeliveries)
                                            {
                                                <div class="d-flex justify-content-end flex-wrap gap-2">
                                                    <a asp-action="EditProofOfDelivery"
                                                           asp-route-id="@item.Id"
                                                           class="btn btn-sm btn-outline-light">
                                                        Редакция
                                                    </a>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Read only</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Няма proof of delivery записи за този shipment.</div>
                }
            </div>
        </div>
    </div>
</div>