@model LogisticManagementApp.Models.CompanyPortal.Shipments.CargoItems.CompanyCargoItemsViewModel

@{
    ViewData["Title"] = "Cargo Items";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Cargo Items</h2>
                        <p class="text-muted mb-0">@Model.ShipmentNo</p>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.CanManageCargoItems)
                        {
                            <a asp-action="CreateCargoItem"
                                   asp-route-shipmentId="@Model.ShipmentId"
                                   class="btn btn-primary">
                                Добави cargo item
                            </a>
                        }

                        <a asp-action="ShipmentDetails"
                               asp-route-id="@Model.ShipmentId"
                               class="btn btn-outline-light">
                            Назад към shipment
                        </a>
                    </div>
                </div>

                @if (Model.CargoItems.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle" data-table-pagination="true" data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Description</th>
                                    <th>Type</th>
                                    <th>Qty / Unit</th>
                                    <th>Weights</th>
                                    <th>Volume</th>
                                    <th>Dimensions</th>
                                    <th>Flags</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CargoItems)
                                {
                                    <tr>
                                        <td>
                                            <div>@item.Description</div>
                                            <small class="text-muted">
                                                HS: @(string.IsNullOrWhiteSpace(item.HsCode) ? "-" : item.HsCode),
                                                Origin: @(string.IsNullOrWhiteSpace(item.OriginCountry) ? "-" : item.OriginCountry)
                                            </small>
                                        </td>
                                        <td>@item.CargoItemType</td>
                                        <td>
                                            @if (item.Quantity.HasValue || !string.IsNullOrWhiteSpace(item.UnitOfMeasure))
                                            {
                                                @($"{item.Quantity?.ToString("0.##") ?? "-"} {item.UnitOfMeasure ?? ""}".Trim())
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                        <td>
                                            Gross: @(item.GrossWeightKg?.ToString("0.##") ?? "-")<br />
                                            Net: @(item.NetWeightKg?.ToString("0.##") ?? "-")
                                        </td>
                                        <td>@(item.VolumeCbm?.ToString("0.###") ?? "-")</td>
                                        <td>
                                            @if (item.LengthCm.HasValue || item.WidthCm.HasValue || item.HeightCm.HasValue)
                                            {
                                                @($"{item.LengthCm?.ToString("0.##") ?? "-"} x {item.WidthCm?.ToString("0.##") ?? "-"} x {item.HeightCm?.ToString("0.##") ?? "-"} cm")
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                        <td>
                                            <div>Stackable: @(item.IsStackable ? "Yes" : "No")</div>
                                            <div>Fragile: @(item.IsFragile ? "Yes" : "No")</div>
                                        </td>
                                        <td class="text-end">
                                            @if (Model.CanManageCargoItems)
                                            {
                                                <div class="d-flex justify-content-end flex-wrap gap-2">
                                                    <a asp-action="EditCargoItem"
                                                           asp-route-id="@item.Id"
                                                           class="btn btn-sm btn-outline-light">
                                                        Редакция
                                                    </a>

                                                    <form asp-action="DeleteCargoItem"
                                                          asp-route-id="@item.Id"
                                                          asp-route-shipmentId="@Model.ShipmentId"
                                                          method="post" data-confirm-message="Сигурен ли си, че искаш да изтриеш този cargo item?">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-light">
                                                            Изтрий
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Read only</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Няма cargo items за този shipment.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
