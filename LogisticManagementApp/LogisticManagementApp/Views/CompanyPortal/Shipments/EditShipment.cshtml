@model LogisticManagementApp.Models.CompanyPortal.Shipments.CompanyShipmentEditViewModel
@using LogisticManagementApp.Domain.Enums.Shipments

@{
    ViewData["Title"] = "Редакция на shipment";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h2 class="h4 mb-1">Редакция на shipment</h2>
                    <p class="text-muted mb-0">@Model.ShipmentNo | @Model.Status</p>
                </div>

                <form asp-action="EditShipment" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="OrderId" class="form-label"></label>
                            <select asp-for="OrderId" asp-items="Model.OrderOptions" class="form-select">
                                <option value="">Без обвързана поръчка</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="PrimaryMode" class="form-label"></label>
                            <select asp-for="PrimaryMode" asp-items="Html.GetEnumSelectList<TransportMode>()" class="form-select"></select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="SenderAddressId" class="form-label"></label>
                            <select asp-for="SenderAddressId" asp-items="Model.AddressOptions" class="form-select">
                                <option value="">Изберете sender address</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="ReceiverAddressId" class="form-label"></label>
                            <select asp-for="ReceiverAddressId" asp-items="Model.AddressOptions" class="form-select">
                                <option value="">Изберете receiver address</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Incoterm" class="form-label"></label>
                            <select asp-for="Incoterm" asp-items="Html.GetEnumSelectList<Incoterm>()" class="form-select">
                                <option value="">Без incoterm</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="DeclaredValue" class="form-label"></label>
                            <input asp-for="DeclaredValue" class="form-control" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Currency" class="form-label"></label>
                            <input asp-for="Currency" class="form-control" placeholder="EUR" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="CustomerReference" class="form-label"></label>
                            <input asp-for="CustomerReference" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-primary">Запази</button>
                        <a asp-action="ShipmentDetails" asp-route-id="@Model.Id" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>