@model LogisticManagementApp.Models.CompanyPortal.Shipments.TrackingEvents.CompanyTrackingEventCreateViewModel
@using LogisticManagementApp.Domain.Enums.Shipments

@{
    ViewData["Title"] = "Нов Tracking Event";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h2 class="h4 mb-1">Нов Tracking Event</h2>
                    <p class="text-muted mb-0">@Model.ShipmentNo</p>
                </div>

                <form asp-action="CreateTrackingEvent" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="ShipmentId" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="EventType" class="form-label"></label>
                            <select asp-for="EventType" asp-items="Html.GetEnumSelectList<TrackingEventType>()" class="form-select"></select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="EventTimeUtc" class="form-label"></label>
                            <input asp-for="EventTimeUtc" class="form-control" type="datetime-local" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="LocationId" class="form-label"></label>
                            <select asp-for="LocationId" asp-items="Model.LocationOptions" class="form-select">
                                <option value="">Без location</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Source" class="form-label"></label>
                            <input asp-for="Source" class="form-control" placeholder="UI" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Details" class="form-label"></label>
                            <textarea asp-for="Details" class="form-control" rows="4"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-primary">Запази</button>
                        <a asp-action="TrackingEvents"
                               asp-route-shipmentId="@Model.ShipmentId"
                               class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>