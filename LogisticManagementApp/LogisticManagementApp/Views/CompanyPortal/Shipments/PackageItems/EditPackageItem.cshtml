@model LogisticManagementApp.Models.CompanyPortal.Shipments.PackageItems.CompanyPackageItemEditViewModel

@{
    ViewData["Title"] = "Редакция на Package Item";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h2 class="h4 mb-1">Редакция на Package Item</h2>
                    <p class="text-muted mb-0">@Model.ShipmentNo / @Model.PackageNo</p>
                </div>

                <form asp-action="EditPackageItem" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="PackageId" type="hidden" />
                    <input asp-for="ShipmentId" type="hidden" />


                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Unit" class="form-label"></label>
                            <input asp-for="Unit" class="form-control" />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-4">
                            <label asp-for="HsCode" class="form-label"></label>
                            <input asp-for="HsCode" class="form-control" />
                            <span asp-validation-for="HsCode" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-4">
                            <label asp-for="OriginCountry" class="form-label"></label>
                            <input asp-for="OriginCountry" class="form-control" />
                            <span asp-validation-for="OriginCountry" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-4">
                            <label asp-for="Currency" class="form-label"></label>
                            <input asp-for="Currency" class="form-control" />
                            <span asp-validation-for="Currency" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="UnitPrice" class="form-label"></label>
                            <input asp-for="UnitPrice" class="form-control" />
                            <span asp-validation-for="UnitPrice" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-primary">Запази</button>
                        <a asp-action="PackageItems"
                               asp-route-packageId="@Model.PackageId"
                               class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
