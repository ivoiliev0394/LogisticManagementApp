@model LogisticManagementApp.Models.CompanyPortal.Shipments.PackageItems.CompanyPackageItemsViewModel

@{
    ViewData["Title"] = "Package Items";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Package Items</h2>
                        <p class="text-muted mb-0">@Model.ShipmentNo / @Model.PackageNo</p>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.CanManagePackageItems)
                        {
                            <a asp-action="CreatePackageItem"
                                   asp-route-packageId="@Model.PackageId"
                                   class="btn btn-primary">
                                Добави item
                            </a>
                        }

                        <a asp-action="Packages"
                               asp-route-shipmentId="@Model.ShipmentId"
                               class="btn btn-outline-light">
                            Назад към packages
                        </a>
                    </div>
                </div>

                @if (Model.PackageItems.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle" data-table-pagination="true" data-page-size="8">
                            <thead>
                                <tr>
                                    <th>Description</th>
                                    <th>Qty</th>
                                    <th>Unit</th>
                                    <th>HS Code</th>
                                    <th>Origin</th>
                                    <th>Unit Price</th>
                                    <th>Currency</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.PackageItems)
                                {
                                    <tr>
                                        <td>@item.Description</td>
                                        <td>@item.Quantity.ToString("0.##")</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Unit) ? "-" : item.Unit)</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.HsCode) ? "-" : item.HsCode)</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.OriginCountry) ? "-" : item.OriginCountry)</td>
                                        <td>@(item.UnitPrice?.ToString("0.##") ?? "-")</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Currency) ? "-" : item.Currency)</td>
                                        <td class="text-end">
                                            @if (Model.CanManagePackageItems)
                                            {
                                                <div class="d-flex justify-content-end flex-wrap gap-2">
                                                    <a asp-action="EditPackageItem"
                                                           asp-route-id="@item.Id"
                                                           class="btn btn-sm btn-outline-light">
                                                        Редакция
                                                    </a>

                                                    <form asp-action="DeletePackageItem"
                                                          asp-route-id="@item.Id"
                                                          asp-route-packageId="@Model.PackageId"
                                                          method="post"
                                                          onsubmit="return confirm('Сигурен ли си, че искаш да изтриеш този package item?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-light">
                                                            Изтрий
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Read only</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Няма items за този package.</div>
                }
            </div>
        </div>
    </div>
</div>