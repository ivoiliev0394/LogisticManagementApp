@model LogisticManagementApp.Models.CompanyPortal.Shipments.Packages.CompanyPackagesViewModel

@{
    ViewData["Title"] = "Packages";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Packages</h2>
                        <p class="text-muted mb-0">@Model.ShipmentNo</p>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.CanManagePackages)
                        {
                            <a asp-action="CreatePackage"
                                   asp-route-shipmentId="@Model.ShipmentId"
                                   class="btn btn-primary">
                                Добави Package
                            </a>
                        }

                        <a asp-action="ShipmentDetails"
                               asp-route-id="@Model.ShipmentId"
                               class="btn btn-outline-light">
                            Назад към shipment
                        </a>
                    </div>
                </div>

                @if (Model.Packages.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle" data-table-pagination="true" data-page-size="6">
                            <thead>
                                <tr>
                                    <th>Package No</th>
                                    <th>Type</th>
                                    <th>Weight</th>
                                    <th>Dimensions</th>
                                    <th>Volume</th>
                                    <th>Items</th>
                                    <th>Notes</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Packages)
                                {
                                    <tr>
                                        <td>@item.PackageNo</td>
                                        <td>@item.PackageType</td>
                                        <td>@item.WeightKg</td>
                                        <td>
                                            @if (item.LengthCm.HasValue || item.WidthCm.HasValue || item.HeightCm.HasValue)
                                            {
                                                <span>
                                                    @(item.LengthCm?.ToString() ?? "-")
                                                    x
                                                    @(item.WidthCm?.ToString() ?? "-")
                                                    x
                                                    @(item.HeightCm?.ToString() ?? "-")
                                                </span>
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                        <td>@(item.VolumeCbm?.ToString() ?? "-")</td>
                                        <td>@item.ItemsCount</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)</td>
                                        <td class="text-end">
                                            @if (Model.CanManagePackages)
                                            {
                                                <a asp-action="PackageItems"
                                                       asp-route-packageId="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Items
                                                </a>

                                                <div class="d-flex justify-content-end flex-wrap gap-2">
                                                    <a asp-action="EditPackage"
                                                           asp-route-id="@item.Id"
                                                           class="btn btn-sm btn-outline-light">
                                                        Редакция
                                                    </a>

                                                    <form asp-action="DeletePackage"
                                                          asp-route-id="@item.Id"
                                                          asp-route-shipmentId="@Model.ShipmentId"
                                                          method="post"
                                                          onsubmit="return confirm('Сигурен ли си, че искаш да изтриеш този package?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-light">
                                                            Изтрий
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Read only</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Няма packages за този shipment.</div>
                }
            </div>
        </div>
    </div>
</div>