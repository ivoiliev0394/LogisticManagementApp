@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Branches.CompanyBranchListItemViewModel>

@{
    ViewData["Title"] = "Клонове";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <span class="badge bg-success mb-2">Клонове</span>
                        <h2 class="h4 mb-1">Управление на клонове</h2>
                        <p class="text-muted mb-0">Управлявайте офисите и локациите на вашата фирма.</p>
                    </div>

                    <a asp-action="CreateBranch" class="btn btn-primary">
                        Добави нов клон
                    </a>
                </div>
@if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">
                        Все още няма добавени клонове.
                    </div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0" data-table-pagination="true" data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Име</th>
                                    <th>Код</th>
                                    <th>Телефон</th>
                                    <th>Имейл</th>
                                    <th>Адрес</th>
                                    <th>Централа</th>
                                    <th>Активен</th>
                                    <th>Бележки</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var branch in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">@branch.Name</td>
                                        <td>@(string.IsNullOrWhiteSpace(branch.BranchCode) ? "-" : branch.BranchCode)</td>
                                        <td>@(string.IsNullOrWhiteSpace(branch.Phone) ? "-" : branch.Phone)</td>
                                        <td>@(string.IsNullOrWhiteSpace(branch.Email) ? "-" : branch.Email)</td>
                                        <td>@(string.IsNullOrWhiteSpace(branch.AddressText) ? "-" : branch.AddressText)</td>
                                        <td>@(branch.IsHeadOffice ? "Да" : "Не")</td>
                                        <td>@(branch.IsActive ? "Да" : "Не")</td>
                                        <td>@(string.IsNullOrWhiteSpace(branch.Notes) ? "-" : branch.Notes)</td>
                                        <td class="text-end">
                                            <div class="d-flex flex-column flex-md-row gap-2 justify-content-md-end">
                                                <a asp-action="EditBranch"
                                                       asp-route-id="@branch.Id"
                                                       class="btn btn-sm btn-warning">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteBranch"
                                                      asp-route-id="@branch.Id"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="btn btn-sm btn-danger" data-confirm-message="Сигурни ли сте, че искате да изтриете този клон?">
                                                        Изтриване
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
