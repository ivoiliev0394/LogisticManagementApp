@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.SharedLocations.AddressListItemViewModel>

@{
    ViewData["Title"] = "Addresses";
}

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Addresses</h2>
                        <p class="text-muted mb-0">Read-only списък с общи адреси.</p>
                    </div>

                    <a asp-action="SharedLocations" class="btn btn-outline-light">
                        Към Shared / Locations
                    </a>
                </div>

                @if (Model.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle"
                               data-table-pagination="true"
                               data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Country / City</th>
                                    <th>Street</th>
                                    <th>Postal</th>
                                    <th>Coordinates</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">
                                                @item.Country / @item.City
                                            </div>
                                            <div class="small text-muted">
                                                @(item.Region ?? "-")
                                            </div>
                                        </td>

                                        <td>
                                            @item.Street
                                            @(item.Building ?? string.Empty)
                                            @(item.Apartment ?? string.Empty)
                                        </td>

                                        <td>@(item.PostalCode ?? "-")</td>

                                        <td>
                                            @(item.Latitude?.ToString() ?? "-") /
                                            @(item.Longitude?.ToString() ?? "-")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Няма записи.</div>
                }
            </div>
        </div>
    </div>
</div>
