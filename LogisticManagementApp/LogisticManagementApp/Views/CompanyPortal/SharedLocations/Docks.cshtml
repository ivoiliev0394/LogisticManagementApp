@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.SharedLocations.DockListItemViewModel>

@{
    ViewData["Title"] = "Docks";
}

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Docks</h2>
                        <p class="text-muted mb-0">Read-only списък с docks.</p>
                    </div>

                    <a asp-action="SharedLocations" class="btn btn-outline-light">
                        Към Shared / Locations
                    </a>
                </div>

                @if (Model.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle"
                               data-table-pagination="true"
                               data-page-size="8">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Parent</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th>Limits</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.Code</div>
                                            <div class="small text-muted">
                                                @(item.Notes ?? "-")
                                            </div>
                                        </td>

                                        <td>@item.ParentDisplay</td>

                                        <td>@item.DockType</td>

                                        <td>
                                            @item.Status /
                                            @(item.IsActive ? "Active" : "Inactive")
                                        </td>

                                        <td>
                                            @(item.MaxWeightKg?.ToString() ?? "-") kg /
                                            @(item.MaxVolumeCbm?.ToString() ?? "-") cbm
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Няма записи.</div>
                }
            </div>
        </div>
    </div>
</div>