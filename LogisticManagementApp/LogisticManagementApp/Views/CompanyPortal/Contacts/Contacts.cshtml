@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Contacts.CompanyContactListItemViewModel>

@{
    ViewData["Title"] = "Контакти";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Контакти</h2>
                        <p class="text-muted mb-0">Управлявайте контактните лица на вашата фирма.</p>
                    </div>

                    <a asp-action="CreateContact" class="btn btn-primary">
                        Добави контакт
                    </a>
                </div>

                <partial name="_StatusMessage" />

                @if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">
                        Все още няма добавени контакти.
                    </div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0" data-table-pagination="true" data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Име</th>
                                    <th>Имейл</th>
                                    <th>Телефон</th>
                                    <th>Длъжност</th>
                                    <th>Основен</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var contact in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">@contact.FullName</td>
                                        <td>@(string.IsNullOrWhiteSpace(contact.Email) ? "-" : contact.Email)</td>
                                        <td>@(string.IsNullOrWhiteSpace(contact.Phone) ? "-" : contact.Phone)</td>
                                        <td>@(string.IsNullOrWhiteSpace(contact.RoleTitle) ? "-" : contact.RoleTitle)</td>
                                        <td>@(contact.IsPrimary ? "Да" : "Не")</td>
                                        <td class="text-end">
                                            <div class="d-flex flex-column flex-md-row gap-2 justify-content-md-end">
                                                <a asp-action="EditContact"
                                                       asp-route-id="@contact.Id"
                                                       class="btn btn-sm btn-warning">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteContact"
                                                      asp-route-id="@contact.Id"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="btn btn-sm btn-danger"
                                                            onclick="return confirm('Сигурни ли сте, че искате да изтриете този контакт?');">
                                                        Изтриване
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>