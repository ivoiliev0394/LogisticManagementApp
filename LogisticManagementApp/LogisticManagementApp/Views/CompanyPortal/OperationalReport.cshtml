@model LogisticManagementApp.Models.CompanyPortal.Reports.CompanyOperationalReportViewModel
@{
    ViewData["Title"] = "Company Operational Report";
}

<div class="report-page">
    <div class="report-toolbar d-flex justify-content-between align-items-center mb-3 no-print">
        <div>
            <div class="text-muted small text-uppercase">PDF Export</div>
            <h1 class="h3 mb-0">Company Operational Report</h1>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-success" onclick="window.print()">Export PDF</button>
            <a asp-action="Reports" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>

    <div class="report-shell print-area">
        <div class="report-hero">
            <div>
                <div class="report-kicker">Company Portal</div>
                <div class="report-title">Company Operational Report</div>
                <div class="report-subtitle">@Model.CompanyName</div>
            </div>
            <div class="report-meta text-end">
                <div>Generated: @Model.GeneratedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                <div>Source: @Model.SourceName</div>
            </div>
        </div>

        <section class="report-section">
            <h2 class="report-section-title">Summary</h2>
            <div class="report-section-note">Key indicators prepared for quick screen review and clean PDF export.</div>
            <div class="report-stats-grid stats-6">
                <div class="report-stat"><span>Orders</span><strong>@Model.OrdersCount</strong></div>
                <div class="report-stat"><span>Shipments</span><strong>@Model.ShipmentsCount</strong></div>
                <div class="report-stat"><span>Active Shipments</span><strong>@Model.ActiveShipmentsCount</strong></div>
                <div class="report-stat"><span>Invoices</span><strong>@Model.InvoicesCount</strong></div>
                <div class="report-stat"><span>Routes</span><strong>@Model.RoutesCount</strong></div>
                <div class="report-stat"><span>Bookings</span><strong>@Model.BookingsCount</strong></div>
            </div>
        </section>

        <section class="report-section">
            <h2 class="report-section-title">Recent Orders</h2>
            <div class="report-section-note">Latest operational records from the company workflow.</div>
            <table class="report-table">
                <thead>
                    <tr><th>Order No</th><th>Status</th><th>Priority</th><th>Pickup Date</th><th>Reference</th></tr>
                </thead>
                <tbody>
                @foreach (var row in Model.RecentOrders)
                {
                    <tr><td>@row.OrderNo</td><td>@row.Status</td><td>@row.Priority</td><td>@row.PickupDate</td><td>@row.Reference</td></tr>
                }
                </tbody>
            </table>
        </section>
    </div>
</div>
