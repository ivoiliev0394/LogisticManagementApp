@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Compliance.ComplianceCheckListItemViewModel>

@{
    ViewData["Title"] = "Compliance Checks";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Compliance Checks</h2>
                        <p class="text-muted mb-0">Проверки за съответствие по shipments.</p>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="CreateComplianceCheck" class="btn btn-primary">
                            Нов запис
                        </a>
                    </div>
                </div>

                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Shipment</th>
                                    <th>Status</th>
                                    <th>Checked</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.ShipmentNo</td>
                                        <td>@item.Status</td>
                                        <td>@item.CheckedAtUtc?.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-2">
                                                <a asp-action="EditComplianceCheck"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteComplianceCheck"
                                                      asp-route-id="@item.Id"
                                                      method="post">
                                                    @Html.AntiForgeryToken()
                                                    <button class="btn btn-sm btn-outline-light">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Няма записи.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
