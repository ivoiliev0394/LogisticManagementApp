@model LogisticManagementApp.Models.CompanyPortal.Compliance.DGDocumentEditViewModel

@{
    ViewData["Title"] = "Редакция на DG document";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Редакция на DG document</h2>

                <form asp-action="EditDGDocument" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Важно за Edit -->
                    <input type="hidden" asp-for="Id" />


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="DangerousGoodsDeclarationId" class="form-label"></label>
                            <select asp-for="DangerousGoodsDeclarationId"
                                    asp-items="Model.DangerousGoodsDeclarationOptions"
                                    class="form-select">
                                <option value="">Избери declaration</option>
                            </select>
                            <span asp-validation-for="DangerousGoodsDeclarationId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FileResourceId" class="form-label"></label>
                            <select asp-for="FileResourceId"
                                    asp-items="Model.FileResourceOptions"
                                    class="form-select">
                                <option value="">Избери file resource</option>
                            </select>
                            <span asp-validation-for="FileResourceId" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="DocumentName" class="form-label"></label>
                            <input asp-for="DocumentName" class="form-control" />
                            <span asp-validation-for="DocumentName" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="DGDocuments" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}