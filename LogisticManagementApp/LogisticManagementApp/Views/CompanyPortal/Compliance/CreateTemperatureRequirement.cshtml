@model LogisticManagementApp.Models.CompanyPortal.Compliance.TemperatureRequirementCreateViewModel

@{
    ViewData["Title"] = "Ново temperature requirement";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Ново temperature requirement</h2>

                <form asp-action="CreateTemperatureRequirement" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ShipmentId" class="form-label"></label>
                            <select asp-for="ShipmentId"
                                    asp-items="Model.ShipmentOptions"
                                    class="form-select">
                                <option value="">Избери shipment</option>
                            </select>
                            <span asp-validation-for="ShipmentId" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="MinTemperatureCelsius" class="form-label"></label>
                            <input asp-for="MinTemperatureCelsius" class="form-control" />
                            <span asp-validation-for="MinTemperatureCelsius" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="MaxTemperatureCelsius" class="form-label"></label>
                            <input asp-for="MaxTemperatureCelsius" class="form-control" />
                            <span asp-validation-for="MaxTemperatureCelsius" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TemperatureUnit" class="form-label"></label>
                            <input asp-for="TemperatureUnit" class="form-control" />
                            <span asp-validation-for="TemperatureUnit" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <div class="form-check mt-4 pt-2">
                                <input asp-for="RequiresTemperatureMonitoring" class="form-check-input" />
                                <span asp-validation-for="RequiresTemperatureMonitoring" class="text-danger"></span>
                                <label asp-for="RequiresTemperatureMonitoring" class="form-check-label">
                                    Requires monitoring
                                </label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="TemperatureRequirements" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}