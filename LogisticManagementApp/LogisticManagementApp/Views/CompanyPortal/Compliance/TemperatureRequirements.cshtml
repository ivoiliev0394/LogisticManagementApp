@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Compliance.TemperatureRequirementListItemViewModel>

@{
    ViewData["Title"] = "Temperature Requirements";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Temperature Requirements</h2>
                        <p class="text-muted mb-0">
                            Температурни изисквания за shipments.
                        </p>
                    </div>

                    <a asp-action="CreateTemperatureRequirement" class="btn btn-success">
                        Ново изискване
                    </a>
                </div>

                <partial name="_StatusMessage" />

                @if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">
                        Няма налични записи.
                    </div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0"
                               data-table-pagination="true"
                               data-page-size="10">

                            <thead>
                                <tr>
                                    <th>Shipment</th>
                                    <th>Min</th>
                                    <th>Max</th>
                                    <th>Monitoring</th>
                                    <th>Unit</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">
                                            @item.ShipmentNo
                                        </td>

                                        <td>
                                            @(item.MinTemperatureCelsius?.ToString("F1") ?? "-")
                                        </td>

                                        <td>
                                            @(item.MaxTemperatureCelsius?.ToString("F1") ?? "-")
                                        </td>

                                        <td>
                                            @(item.RequiresTemperatureMonitoring ? "Да" : "Не")
                                        </td>

                                        <td>
                                            @(item.TemperatureUnit ?? "-")
                                        </td>

                                        <td class="text-end">
                                            <div class="d-flex gap-2 justify-content-end">
                                                <a asp-action="EditTemperatureRequirement"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteTemperatureRequirement"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="id" value="@item.Id" />

                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-danger">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                    </div>
                }

            </div>
        </div>
    </div>
</div>