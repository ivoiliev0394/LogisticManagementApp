@model LogisticManagementApp.Models.CompanyPortal.Compliance.DangerousGoodsDeclarationCreateViewModel
@using LogisticManagementApp.Domain.Enums.Compliance

@{
    ViewData["Title"] = "Нова DG declaration";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нова DG declaration</h2>

                <form asp-action="CreateDangerousGoodsDeclaration" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ShipmentId" class="form-label"></label>
                            <select asp-for="ShipmentId" asp-items="Model.ShipmentOptions" class="form-select">
                                <option value="">Избери shipment</option>
                            </select>
                            <span asp-validation-for="ShipmentId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PackageId" class="form-label"></label>
                            <select asp-for="PackageId" asp-items="Model.PackageOptions" class="form-select">
                                <option value="">Без package</option>
                            </select>
                            <span asp-validation-for="PackageId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="UnNumber" class="form-label"></label>
                            <input asp-for="UnNumber" class="form-control" />
                            <span asp-validation-for="UnNumber" class="text-danger"></span>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="ProperShippingName" class="form-label"></label>
                            <input asp-for="ProperShippingName" class="form-control" />
                            <span asp-validation-for="ProperShippingName" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="HazardClass" class="form-label"></label>
                            <select asp-for="HazardClass"
                                    asp-items="Html.GetEnumSelectList<HazardClass>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="HazardClass" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="PackingGroup" class="form-label"></label>
                            <select asp-for="PackingGroup"
                                    asp-items="Html.GetEnumSelectList<PackingGroup>()"
                                    class="form-select">
                                <option value="">Без group</option>
                            </select>
                            <span asp-validation-for="PackingGroup" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="NetQuantity" class="form-label"></label>
                            <input asp-for="NetQuantity" class="form-control" />
                            <span asp-validation-for="NetQuantity" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="QuantityUnit" class="form-label"></label>
                            <input asp-for="QuantityUnit" class="form-control" />
                            <span asp-validation-for="QuantityUnit" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <div class="form-check mt-4 pt-2">
                                <input asp-for="RequiresSpecialHandling" class="form-check-input" />
                                <span asp-validation-for="RequiresSpecialHandling" class="text-danger"></span>
                                <label asp-for="RequiresSpecialHandling" class="form-check-label">
                                    Requires special handling
                                </label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="HandlingInstructions" class="form-label"></label>
                            <textarea asp-for="HandlingInstructions" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="HandlingInstructions" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="DangerousGoodsDeclarations" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}