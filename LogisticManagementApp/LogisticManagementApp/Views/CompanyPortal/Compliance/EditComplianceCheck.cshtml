@model LogisticManagementApp.Models.CompanyPortal.Compliance.ComplianceCheckEditViewModel
@using LogisticManagementApp.Domain.Enums.Compliance

@{
    ViewData["Title"] = "Редакция на compliance check";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Редакция на compliance check</h2>

                <form asp-action="EditComplianceCheck" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ShipmentId" class="form-label"></label>
                            <select asp-for="ShipmentId"
                                    asp-items="Model.ShipmentOptions"
                                    class="form-select">
                                <option value="">Избери shipment</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CheckType" class="form-label"></label>
                            <input asp-for="CheckType" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status"
                                    asp-items="Html.GetEnumSelectList<ComplianceCheckStatus>()"
                                    class="form-select">
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="CheckedAtUtc" class="form-label"></label>
                            <input asp-for="CheckedAtUtc"
                                   type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="CheckedBy" class="form-label"></label>
                            <input asp-for="CheckedBy" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="ResultDetails" class="form-label"></label>
                            <textarea asp-for="ResultDetails"
                                      class="form-control"
                                      rows="3"></textarea>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="ComplianceChecks" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}