@model LogisticManagementApp.Models.CompanyPortal.Documents.DocumentTemplateEditViewModel

@{
    ViewData["Title"] = "Редакция на document template";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Редакция на document template</h2>

                <form asp-action="EditDocumentTemplate" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TemplateType" class="form-label"></label>
                            <select asp-for="TemplateType" class="form-select"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Orders.DocumentTemplateType>()">
                            </select>
                            <span asp-validation-for="TemplateType" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FileResourceId" class="form-label"></label>
                            <select asp-for="FileResourceId" asp-items="Model.FileResourceOptions" class="form-select">
                                <option value="">Избери file resource</option>
                            </select>
                            <span asp-validation-for="FileResourceId" class="text-danger"></span>
                        </div>

                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="IsDefault" class="form-check-input" />
                                <label asp-for="IsDefault" class="form-check-label"></label>
                            </div>
                        </div>

                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label"></label>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="DocumentTemplates" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}