@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Documents.DocumentTemplateListItemViewModel>

@{
    ViewData["Title"] = "Document Templates";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Document Templates</h2>
                        <p class="text-muted mb-0">Фирмени и глобални шаблони за документи.</p>
                    </div>

                    <a asp-action="CreateDocumentTemplate" class="btn btn-success">Нов template</a>
                </div>

                <partial name="_StatusMessage" />

                @if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">Няма налични записи.</div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0"
                               data-table-pagination="true"
                               data-page-size="10">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th>File</th>
                                    <th>Default</th>
                                    <th>Active</th>
                                    <th>Scope</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">@item.Name</td>
                                        <td>@item.TemplateType</td>
                                        <td>@item.FileName</td>
                                        <td>@(item.IsDefault ? "Да" : "Не")</td>
                                        <td>@(item.IsActive ? "Да" : "Не")</td>
                                        <td>@(item.IsGlobal ? "Global" : "Company")</td>
                                        <td class="text-end">
                                            @if (!item.IsGlobal)
                                            {
                                                <div class="d-flex gap-2 justify-content-end">
                                                    <a asp-action="EditDocumentTemplate"
                                                           asp-route-id="@item.Id"
                                                           class="btn btn-sm btn-outline-light">
                                                        Редакция
                                                    </a>

                                                    <form asp-action="DeleteDocumentTemplate" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            Изтрий
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>