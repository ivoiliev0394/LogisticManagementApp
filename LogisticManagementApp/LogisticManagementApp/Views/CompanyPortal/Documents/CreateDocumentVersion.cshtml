@model LogisticManagementApp.Models.CompanyPortal.Documents.DocumentVersionCreateViewModel

@{
    ViewData["Title"] = "Нова document version";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нова document version</h2>

                <form asp-action="CreateDocumentVersion" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="DocumentId" class="form-label"></label>
                            <select asp-for="DocumentId" asp-items="Model.DocumentOptions" class="form-select">
                                <option value="">Избери document</option>
                            </select>
                            <span asp-validation-for="DocumentId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FileResourceId" class="form-label"></label>
                            <select asp-for="FileResourceId" asp-items="Model.FileResourceOptions" class="form-select">
                                <option value="">Избери file resource</option>
                            </select>
                            <span asp-validation-for="FileResourceId" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="VersionNo" class="form-label"></label>
                            <input asp-for="VersionNo" class="form-control" />
                            <span asp-validation-for="VersionNo" class="text-danger"></span>
                        </div>

                        <div class="col-md-5">
                            <label asp-for="CreatedOnUtc" class="form-label"></label>
                            <input asp-for="CreatedOnUtc" type="datetime-local" class="form-control" />
                            <span asp-validation-for="CreatedOnUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="ChangeDescription" class="form-label"></label>
                            <textarea asp-for="ChangeDescription" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="ChangeDescription" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="DocumentVersions" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}