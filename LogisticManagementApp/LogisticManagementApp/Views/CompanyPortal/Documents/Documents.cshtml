@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Documents.CompanyDocumentListItemViewModel>

@{
    ViewData["Title"] = "Documents";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Documents</h2>
                        <p class="text-muted mb-0">Документи по shipment flow и издадени от фирмата.</p>
                    </div>

                    <a asp-action="CreateDocument" class="btn btn-success">Нов document</a>
                </div>

                <partial name="_StatusMessage" />

                @if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">Няма налични записи.</div>
                }
                else
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle mb-0"
                               data-table-pagination="true"
                               data-page-size="10">
                            <thead>
                                <tr>
                                    <th>Shipment</th>
                                    <th>Type</th>
                                    <th>File</th>
                                    <th>No</th>
                                    <th>Issued</th>
                                    <th>Issuer</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">@item.ShipmentNo</td>
                                        <td>@item.DocumentType</td>
                                        <td>@item.FileName</td>
                                        <td>@(item.DocumentNo ?? "-")</td>
                                        <td>@(item.IssuedAtUtc?.ToString("dd.MM.yyyy") ?? "-")</td>
                                        <td>@(item.IssuedByCompanyName ?? "-")</td>
                                        <td class="text-end">
                                            <div class="d-flex gap-2 justify-content-end">
                                                <a asp-action="EditDocument"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteDocument" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>