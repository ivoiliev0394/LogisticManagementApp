@model LogisticManagementApp.Models.CompanyPortal.Documents.DocumentCreateViewModel
@using LogisticManagementApp.Domain.Enums.Shipments

@{
    ViewData["Title"] = "Нов document";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов document</h2>

                <form asp-action="CreateDocument" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ShipmentId" class="form-label"></label>
                            <select asp-for="ShipmentId" asp-items="Model.ShipmentOptions" class="form-select">
                                <option value="">Избери shipment</option>
                            </select>
                            <span asp-validation-for="ShipmentId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FileResourceId" class="form-label"></label>
                            <select asp-for="FileResourceId" asp-items="Model.FileResourceOptions" class="form-select">
                                <option value="">Избери file resource</option>
                            </select>
                            <span asp-validation-for="FileResourceId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DocumentType" class="form-label"></label>
                            <select asp-for="DocumentType"
                                    asp-items="Html.GetEnumSelectList<DocumentType>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="DocumentType" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DocumentNo" class="form-label"></label>
                            <input asp-for="DocumentNo" class="form-control" />
                            <span asp-validation-for="DocumentNo" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="IssuedAtUtc" class="form-label"></label>
                            <input asp-for="IssuedAtUtc" type="datetime-local" class="form-control" />
                            <span asp-validation-for="IssuedAtUtc" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="Documents" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}