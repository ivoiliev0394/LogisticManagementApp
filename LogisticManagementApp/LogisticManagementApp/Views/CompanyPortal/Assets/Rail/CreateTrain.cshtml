@model LogisticManagementApp.Models.CompanyPortal.Assets.Rail.TrainCreateViewModel

@{
    ViewData["Title"] = "Нов train";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов train</h2>

                <form asp-action="CreateTrain" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="TrainNumber" class="form-label"></label>
                            <input asp-for="TrainNumber" class="form-control" />
                            <span asp-validation-for="TrainNumber" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="TrainType" class="form-label"></label>
                            <select asp-for="TrainType"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Assets.TrainType>()"
                                    class="form-select"></select>
                                    <span asp-validation-for="TrainType" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Assets.AssetStatus>()"
                                    class="form-select"></select>
                                    <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="MaxWeightKg" class="form-label"></label>
                            <input asp-for="MaxWeightKg" class="form-control" />
                            <span asp-validation-for="MaxWeightKg" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="MaxVolumeCbm" class="form-label"></label>
                            <input asp-for="MaxVolumeCbm" class="form-control" />
                            <span asp-validation-for="MaxVolumeCbm" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <div class="form-check mt-4 pt-2">
                                <input asp-for="IsActive" class="form-check-input" />
                                <span asp-validation-for="IsActive" class="text-danger"></span>
                                <label asp-for="IsActive" class="form-check-label">
                                    Активен
                                </label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="Trains" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}