@model LogisticManagementApp.Models.CompanyPortal.Assets.Rail.RailServiceCreateViewModel

@{
    ViewData["Title"] = "Нов rail service";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов rail service</h2>

                <form asp-action="CreateRailService" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="ServiceCode" class="form-label"></label>
                            <input asp-for="ServiceCode" class="form-control" />
                        </div>

                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="OriginLocationId" class="form-label"></label>
                            <select asp-for="OriginLocationId"
                                    asp-items="Model.LocationOptions"
                                    class="form-select">
                                <option value="">-- Избери --</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DestinationLocationId" class="form-label"></label>
                            <select asp-for="DestinationLocationId"
                                    asp-items="Model.LocationOptions"
                                    class="form-select">
                                <option value="">-- Избери --</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EstimatedTransitDays" class="form-label"></label>
                            <input asp-for="EstimatedTransitDays" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <div class="form-check mt-4 pt-2">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label">
                                    Активен
                                </label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="RailServices" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}