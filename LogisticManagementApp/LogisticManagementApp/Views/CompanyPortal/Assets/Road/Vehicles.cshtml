@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Assets.Road.VehicleListItemViewModel>

@{
    ViewData["Title"] = "Vehicles";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Vehicles</h2>
                        <p class="text-muted mb-0">
                            Списък с vehicles за текущата компания.
                        </p>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="RoadAssets" class="btn btn-outline-light">Road</a>
                        <a asp-action="CreateVehicle" class="btn btn-primary">
                            Нов запис
                        </a>
                    </div>
                </div>

                @if (Model.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle"
                               data-table-pagination="true"
                               data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Registration</th>
                                    <th>Type</th>
                                    <th>Brand / Model</th>
                                    <th>Status</th>
                                    <th>Capacity</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.RegistrationNumber</div>
                                            <div class="small text-muted">
                                                @(item.Notes ?? "-")
                                            </div>
                                        </td>

                                        <td>@item.VehicleType</td>

                                        <td>
                                            @((item.Brand ?? "-") + " / " + (item.Model ?? "-"))
                                        </td>

                                        <td>@item.Status</td>

                                        <td>
                                            @(item.MaxWeightKg?.ToString() ?? "-") kg /
                                            @(item.MaxVolumeCbm?.ToString() ?? "-") cbm
                                        </td>

                                        <td class="text-end">
                                            <div class="d-flex flex-wrap justify-content-end gap-2">
                                                <a asp-action="EditVehicle"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteVehicle"
                                                      asp-route-id="@item.Id"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()

                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-light">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Няма записи.</div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
