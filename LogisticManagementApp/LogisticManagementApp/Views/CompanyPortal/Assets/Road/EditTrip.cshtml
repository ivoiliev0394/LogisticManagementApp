@model LogisticManagementApp.Models.CompanyPortal.Assets.Road.TripEditViewModel

@{
    ViewData["Title"] = "Редакция на trip";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Редакция на trip</h2>

                <form asp-action="EditTrip" method="post">
                    @Html.AntiForgeryToken()


                    <input asp-for="Id" type="hidden" />

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="TripNo" class="form-label"></label>
                            <input asp-for="TripNo" class="form-control" />
                            <span asp-validation-for="TripNo" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="VehicleId" class="form-label">Vehicle</label>
                            <select asp-for="VehicleId"
                                    asp-items="Model.VehicleOptions"
                                    class="form-select">
                                <option value="">-- Избери --</option>
                            </select>
                            <span asp-validation-for="VehicleId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DriverId" class="form-label">Driver</label>
                            <select asp-for="DriverId"
                                    asp-items="Model.DriverOptions"
                                    class="form-select">
                                <option value="">-- Избери --</option>
                            </select>
                            <span asp-validation-for="DriverId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="OriginLocationId" class="form-label">Origin</label>
                            <select asp-for="OriginLocationId"
                                    asp-items="Model.LocationOptions"
                                    class="form-select">
                                <option value="">-- Избери --</option>
                            </select>
                            <span asp-validation-for="OriginLocationId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DestinationLocationId" class="form-label">Destination</label>
                            <select asp-for="DestinationLocationId"
                                    asp-items="Model.LocationOptions"
                                    class="form-select">
                                <option value="">-- Избери --</option>
                            </select>
                            <span asp-validation-for="DestinationLocationId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Assets.TripStatus>()"
                                    class="form-select"></select>
                                    <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PlannedDepartureUtc" class="form-label"></label>
                            <input asp-for="PlannedDepartureUtc"
                                   type="datetime-local"
                                   class="form-control" />
                                   <span asp-validation-for="PlannedDepartureUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PlannedArrivalUtc" class="form-label"></label>
                            <input asp-for="PlannedArrivalUtc"
                                   type="datetime-local"
                                   class="form-control" />
                                   <span asp-validation-for="PlannedArrivalUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ActualDepartureUtc" class="form-label"></label>
                            <input asp-for="ActualDepartureUtc"
                                   type="datetime-local"
                                   class="form-control" />
                                   <span asp-validation-for="ActualDepartureUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ActualArrivalUtc" class="form-label"></label>
                            <input asp-for="ActualArrivalUtc"
                                   type="datetime-local"
                                   class="form-control" />
                                   <span asp-validation-for="ActualArrivalUtc" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="Trips" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}