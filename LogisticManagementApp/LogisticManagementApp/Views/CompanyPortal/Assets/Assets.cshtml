@model LogisticManagementApp.Models.CompanyPortal.Assets.Sea.CompanyAssetsHomeViewModel

@{
    ViewData["Title"] = "Assets";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">

                <div class="mb-4">
                    <h2 class="h4 mb-1">Assets</h2>
                    <p class="text-muted mb-0">
                        Избери asset категория за управление на фирмените ресурси.
                    </p>
                </div>

                <div class="row g-4">
                    @foreach (var card in Model.Cards)
                    {
                        <div class="col-12 col-md-6 col-xxl-4">
                            <div class="stat-card h-100 d-flex flex-column">

                                <div class="fw-semibold mb-2 text-muted">
                                    @card.Title
                                </div>

                                <div class="text-muted mb-3">
                                    @card.Description
                                </div>

                                <div class="mt-auto">
                                    <a asp-action="@card.ActionName"
                                           class="btn btn-outline-light">
                                        @card.ButtonText
                                    </a>
                                </div>

                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</div>