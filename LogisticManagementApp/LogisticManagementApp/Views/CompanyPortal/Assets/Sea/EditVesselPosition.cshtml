@model LogisticManagementApp.Models.CompanyPortal.Assets.Sea.VesselPositionEditViewModel

@{
    ViewData["Title"] = "Редакция на vessel position";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Редакция на vessel position</h2>

                <form asp-action="EditVesselPosition" method="post">
                    @Html.AntiForgeryToken()


                    <input asp-for="Id" type="hidden" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="VesselId" class="form-label"></label>
                            <select asp-for="VesselId"
                                    asp-items="Model.VesselOptions"
                                    class="form-select">
                                <option value="">Избери vessel</option>
                            </select>
                            <span asp-validation-for="VesselId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PositionTimeUtc" class="form-label"></label>
                            <input asp-for="PositionTimeUtc"
                                   type="datetime-local"
                                   class="form-control" />
                                   <span asp-validation-for="PositionTimeUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Latitude" class="form-label"></label>
                            <input asp-for="Latitude" class="form-control" />
                            <span asp-validation-for="Latitude" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Longitude" class="form-label"></label>
                            <input asp-for="Longitude" class="form-control" />
                            <span asp-validation-for="Longitude" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="SpeedKnots" class="form-label"></label>
                            <input asp-for="SpeedKnots" class="form-control" />
                            <span asp-validation-for="SpeedKnots" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="CourseDegrees" class="form-label"></label>
                            <input asp-for="CourseDegrees" class="form-control" />
                            <span asp-validation-for="CourseDegrees" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Source" class="form-label"></label>
                            <input asp-for="Source" class="form-control" />
                            <span asp-validation-for="Source" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="VesselPositions" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}