@model LogisticManagementApp.Models.CompanyPortal.Assets.Sea.VoyageStopCreateViewModel

@{
    ViewData["Title"] = "Нов voyage stop";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов voyage stop</h2>

                <form asp-action="CreateVoyageStop" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="VoyageId" class="form-label"></label>
                            <select asp-for="VoyageId"
                                    asp-items="Model.VoyageOptions"
                                    class="form-select">
                                <option value="">Избери voyage</option>
                            </select>
                            <span asp-validation-for="VoyageId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="LocationId" class="form-label"></label>
                            <select asp-for="LocationId"
                                    asp-items="Model.LocationOptions"
                                    class="form-select">
                                <option value="">Избери location</option>
                            </select>
                            <span asp-validation-for="LocationId" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="SequenceNumber" class="form-label"></label>
                            <input asp-for="SequenceNumber" class="form-control" />
                            <span asp-validation-for="SequenceNumber" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="PlannedArrivalUtc" class="form-label"></label>
                            <input asp-for="PlannedArrivalUtc"
                                   type="datetime-local"
                                   class="form-control" />
                                   <span asp-validation-for="PlannedArrivalUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="PlannedDepartureUtc" class="form-label"></label>
                            <input asp-for="PlannedDepartureUtc"
                                   type="datetime-local"
                                   class="form-control" />
                                   <span asp-validation-for="PlannedDepartureUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="ActualArrivalUtc" class="form-label"></label>
                            <input asp-for="ActualArrivalUtc"
                                   type="datetime-local"
                                   class="form-control" />
                                   <span asp-validation-for="ActualArrivalUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ActualDepartureUtc" class="form-label"></label>
                            <input asp-for="ActualDepartureUtc"
                                   type="datetime-local"
                                   class="form-control" />
                                   <span asp-validation-for="ActualDepartureUtc" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                                      <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="VoyageStops" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}