@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Assets.Sea.CrewAssignmentListItemViewModel>

@{
    ViewData["Title"] = "Crew Assignments";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Crew Assignments</h2>
                        <p class="text-muted mb-0">
                            Списък с crew assignments за текущата компания.
                        </p>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="SeaAssets" class="btn btn-outline-light">Sea</a>
                        <a asp-action="CreateCrewAssignment" class="btn btn-primary">
                            Нов запис
                        </a>
                    </div>
                </div>

                @if (Model.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle"
                               data-table-pagination="true"
                               data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Voyage</th>
                                    <th>Vessel</th>
                                    <th>Crew Member</th>
                                    <th>Role</th>
                                    <th>Assigned</th>
                                    <th>Period</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.VoyageNumber</td>

                                        <td>@item.VesselName</td>

                                        <td>
                                            <div class="fw-semibold">@item.CrewMemberName</div>
                                            <div class="small text-muted">
                                                @(item.Notes ?? "-")
                                            </div>
                                        </td>

                                        <td>@item.AssignedRole</td>

                                        <td>
                                            @(item.AssignedAtUtc?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                                        </td>

                                        <td>
                                            @(item.FromUtc?.ToString("dd.MM.yyyy") ?? "-")
                                            -
                                            @(item.ToUtc?.ToString("dd.MM.yyyy") ?? "-")
                                        </td>

                                        <td class="text-end">
                                            <div class="d-flex flex-wrap justify-content-end gap-2">
                                                <a asp-action="EditCrewAssignment"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteCrewAssignment"
                                                      asp-route-id="@item.Id"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()

                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-light">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Няма записи.</div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
