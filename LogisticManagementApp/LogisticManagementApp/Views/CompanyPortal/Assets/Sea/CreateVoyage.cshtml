@model LogisticManagementApp.Models.CompanyPortal.Assets.Sea.VoyageCreateViewModel

@{
    ViewData["Title"] = "Нов voyage";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов voyage</h2>

                <form asp-action="CreateVoyage" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="VesselId" class="form-label"></label>
                            <select asp-for="VesselId"
                                    asp-items="Model.VesselOptions"
                                    class="form-select">
                                <option value="">Избери vessel</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="VoyageNumber" class="form-label"></label>
                            <input asp-for="VoyageNumber" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Assets.TripStatus>()"
                                    class="form-select"></select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="OriginPort" class="form-label"></label>
                            <input asp-for="OriginPort" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DestinationPort" class="form-label"></label>
                            <input asp-for="DestinationPort" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PlannedDepartureUtc" class="form-label"></label>
                            <input asp-for="PlannedDepartureUtc"
                                   type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PlannedArrivalUtc" class="form-label"></label>
                            <input asp-for="PlannedArrivalUtc"
                                   type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ActualDepartureUtc" class="form-label"></label>
                            <input asp-for="ActualDepartureUtc"
                                   type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ActualArrivalUtc" class="form-label"></label>
                            <input asp-for="ActualArrivalUtc"
                                   type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="Voyages" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}