@model LogisticManagementApp.Models.CompanyPortal.Assets.Sea.CrewAssignmentCreateViewModel

@{
    ViewData["Title"] = "Нов crew assignment";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов crew assignment</h2>

                <form asp-action="CreateCrewAssignment" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="VoyageId" class="form-label"></label>
                            <select asp-for="VoyageId"
                                    asp-items="Model.VoyageOptions"
                                    class="form-select">
                                <option value="">Избери voyage</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="VesselCrewMemberId" class="form-label"></label>
                            <select asp-for="VesselCrewMemberId"
                                    asp-items="Model.CrewMemberOptions"
                                    class="form-select">
                                <option value="">Избери crew member</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="AssignedRole" class="form-label"></label>
                            <select asp-for="AssignedRole"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Assets.VesselCrewRole>()"
                                    class="form-select"></select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="AssignedAtUtc" class="form-label"></label>
                            <input asp-for="AssignedAtUtc"
                                   type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="FromUtc" class="form-label"></label>
                            <input asp-for="FromUtc"
                                   type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ToUtc" class="form-label"></label>
                            <input asp-for="ToUtc"
                                   type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="CrewAssignments" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}