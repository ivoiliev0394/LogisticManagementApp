@model LogisticManagementApp.Models.CompanyPortal.Operations.BookingCreateViewModel

@{
    ViewData["Title"] = "Нов booking";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов booking</h2>

                <form asp-action="CreateBooking" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="BookingNo" class="form-label"></label>
                            <input asp-for="BookingNo" class="form-control" />
                            <span asp-validation-for="BookingNo" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="CarrierCompanyId" class="form-label"></label>
                            <select asp-for="CarrierCompanyId"
                                    asp-items="Model.CarrierCompanyOptions"
                                    class="form-select">
                                <option value="">Без carrier</option>
                            </select>
                            <span asp-validation-for="CarrierCompanyId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ShipmentId" class="form-label"></label>
                            <select asp-for="ShipmentId"
                                    asp-items="Model.ShipmentOptions"
                                    class="form-select">
                                <option value="">Без shipment</option>
                            </select>
                            <span asp-validation-for="ShipmentId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Operations.BookingStatus>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="TransportMode" class="form-label"></label>
                            <select asp-for="TransportMode"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Shipments.TransportMode>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="TransportMode" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="CarrierReference" class="form-label"></label>
                            <input asp-for="CarrierReference" class="form-control" />
                            <span asp-validation-for="CarrierReference" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="RequestedAtUtc" class="form-label"></label>
                            <input asp-for="RequestedAtUtc" type="datetime-local" class="form-control" />
                            <span asp-validation-for="RequestedAtUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConfirmedAtUtc" class="form-label"></label>
                            <input asp-for="ConfirmedAtUtc" type="datetime-local" class="form-control" />
                            <span asp-validation-for="ConfirmedAtUtc" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="Bookings" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}