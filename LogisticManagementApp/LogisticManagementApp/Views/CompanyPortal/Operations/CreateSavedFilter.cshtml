@model LogisticManagementApp.Models.CompanyPortal.Operations.SavedFilterCreateViewModel

@{
    ViewData["Title"] = "Нов saved filter";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов saved filter</h2>

                <form asp-action="CreateSavedFilter" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EntityType" class="form-label"></label>
                            <input asp-for="EntityType" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UserId" class="form-label"></label>
                            <select asp-for="UserId" asp-items="Model.UserOptions" class="form-select">
                                <option value="">Ниво компания</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <div class="form-check mt-4 pt-2">
                                <input asp-for="IsDefault" class="form-check-input" />
                                <label asp-for="IsDefault" class="form-check-label">Default</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="FilterJson" class="form-label"></label>
                            <textarea asp-for="FilterJson" class="form-control" rows="6"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="SavedFilters" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}