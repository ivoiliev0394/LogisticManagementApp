@model LogisticManagementApp.Models.CompanyPortal.Operations.ResourceCalendarCreateViewModel

@{
    ViewData["Title"] = "Нов resource calendar";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов resource calendar</h2>

                <form asp-action="CreateResourceCalendar" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="ResourceType" class="form-label"></label>
                            <select asp-for="ResourceType"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Operations.ResourceType>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="ResourceType" class="text-danger"></span>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="ResourceId" class="form-label"></label>
                            <select asp-for="ResourceId"
                                    asp-items="Model.ResourceOptions"
                                    class="form-select">
                                <option value="">Избери resource</option>
                            </select>
                            <span asp-validation-for="ResourceId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DateUtc" class="form-label"></label>
                            <input asp-for="DateUtc" type="datetime-local" class="form-control" />
                            <span asp-validation-for="DateUtc" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Operations.AvailabilityStatus>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="PlannedCapacity" class="form-label"></label>
                            <input asp-for="PlannedCapacity" class="form-control" />
                            <span asp-validation-for="PlannedCapacity" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ReservedCapacity" class="form-label"></label>
                            <input asp-for="ReservedCapacity" class="form-control" />
                            <span asp-validation-for="ReservedCapacity" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UsedCapacity" class="form-label"></label>
                            <input asp-for="UsedCapacity" class="form-control" />
                            <span asp-validation-for="UsedCapacity" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="ResourceCalendars" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}