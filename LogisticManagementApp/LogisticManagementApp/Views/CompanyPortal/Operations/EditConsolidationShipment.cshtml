@model LogisticManagementApp.Models.CompanyPortal.Operations.ConsolidationShipmentEditViewModel

@{
    ViewData["Title"] = "Редакция на consolidation shipment";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Редакция на consolidation shipment</h2>

                <form asp-action="EditConsolidationShipment" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="ConsolidationId" class="form-label"></label>
                            <select asp-for="ConsolidationId"
                                    asp-items="Model.ConsolidationOptions"
                                    class="form-select">
                                <option value="">Избери consolidation</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ShipmentId" class="form-label"></label>
                            <select asp-for="ShipmentId"
                                    asp-items="Model.ShipmentOptions"
                                    class="form-select">
                                <option value="">Избери shipment</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ShipmentLegId" class="form-label"></label>
                            <select asp-for="ShipmentLegId"
                                    asp-items="Model.ShipmentLegOptions"
                                    class="form-select">
                                <option value="">Без shipment leg</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="AllocatedWeightKg" class="form-label"></label>
                            <input asp-for="AllocatedWeightKg"
                                   type="number"
                                   step="0.01"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="AllocatedVolumeCbm" class="form-label"></label>
                            <input asp-for="AllocatedVolumeCbm"
                                   type="number"
                                   step="0.01"
                                   class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">
                            Запази
                        </button>

                        <a asp-action="ConsolidationShipments" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}