@model LogisticManagementApp.Models.CompanyPortal.Operations.BookingLegEditViewModel

@{
    ViewData["Title"] = "Редакция на booking leg";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Редакция на booking leg</h2>

                <form asp-action="EditBookingLeg" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="BookingId" class="form-label"></label>
                            <select asp-for="BookingId"
                                    asp-items="Model.BookingOptions"
                                    class="form-select">
                                <option value="">Избери booking</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ShipmentLegId" class="form-label"></label>
                            <select asp-for="ShipmentLegId"
                                    asp-items="Model.ShipmentLegOptions"
                                    class="form-select">
                                <option value="">Без shipment leg</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="LegNo" class="form-label"></label>
                            <input asp-for="LegNo"
                                   type="number"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="OriginLocationId" class="form-label"></label>
                            <select asp-for="OriginLocationId"
                                    asp-items="Model.LocationOptions"
                                    class="form-select">
                                <option value="">Без origin</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DestinationLocationId" class="form-label"></label>
                            <select asp-for="DestinationLocationId"
                                    asp-items="Model.LocationOptions"
                                    class="form-select">
                                <option value="">Без destination</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ETD_Utc" class="form-label"></label>
                            <input asp-for="ETD_Utc"
                                   type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ETA_Utc" class="form-label"></label>
                            <input asp-for="ETA_Utc"
                                   type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CarrierReference" class="form-label"></label>
                            <input asp-for="CarrierReference"
                                   class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">
                            Запази
                        </button>

                        <a asp-action="BookingLegs" class="btn btn-outline-light">
                            Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}