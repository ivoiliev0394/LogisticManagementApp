@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Operations.UtilizationSnapshotListItemViewModel>

@{
    ViewData["Title"] = "Utilization Snapshots";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Utilization Snapshots</h2>
                        <p class="text-muted mb-0">
                            Read-only utilization snapshots по ресурси.
                        </p>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Operations" class="btn btn-outline-light">
                            Към Operations
                        </a>
                    </div>
                </div>

                @if (Model.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle"
                               data-table-pagination="true"
                               data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Resource</th>
                                    <th>Date</th>
                                    <th>Total</th>
                                    <th>Used</th>
                                    <th>%</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">
                                                @item.ResourceDisplay
                                            </div>
                                            <div class="small text-muted">
                                                @item.ResourceType
                                            </div>
                                        </td>

                                        <td>
                                            @item.SnapshotDateUtc.ToString("yyyy-MM-dd")
                                        </td>

                                        <td>
                                            @(item.TotalCapacity?.ToString("F2") ?? "-")
                                        </td>

                                        <td>
                                            @(item.UsedCapacity?.ToString("F2") ?? "-")
                                        </td>

                                        <td>
                                            @(item.UtilizationPercent?.ToString("F2") ?? "-")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">
                        Няма записи.
                    </div>
                }
            </div>
        </div>
    </div>
</div>