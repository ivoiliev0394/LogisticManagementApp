@model LogisticManagementApp.Models.CompanyPortal.Operations.CompanyDashboardConfigCreateViewModel

@{
    ViewData["Title"] = "Нов dashboard config";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов dashboard config</h2>

                <form asp-action="CreateCompanyDashboardConfig" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="DashboardKey" class="form-label"></label>
                            <input asp-for="DashboardKey" class="form-control" />
                            <span asp-validation-for="DashboardKey" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <div class="form-check mt-4 pt-2">
                                <input asp-for="IsActive" class="form-check-input" />
                                <span asp-validation-for="IsActive" class="text-danger"></span>
                                <label asp-for="IsActive" class="form-check-label">Активен</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="LayoutJson" class="form-label"></label>
                            <textarea asp-for="LayoutJson" class="form-control" rows="6"></textarea>
                            <span asp-validation-for="LayoutJson" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="WidgetSettingsJson" class="form-label"></label>
                            <textarea asp-for="WidgetSettingsJson" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="WidgetSettingsJson" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="CompanyDashboardConfigs" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}