@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Operations.NotificationListItemViewModel>

@{
    ViewData["Title"] = "Notifications";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Notifications</h2>
                        <p class="text-muted mb-0">
                            Известия към фирмата и нейните потребители.
                        </p>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Operations" class="btn btn-outline-light">
                            Към Operations
                        </a>

                        <a asp-action="CreateNotification" class="btn btn-primary">
                            Нов запис
                        </a>
                    </div>
                </div>

                @if (Model.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle"
                               data-table-pagination="true"
                               data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Type</th>
                                    <th>Channel</th>
                                    <th>User</th>
                                    <th>Read</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">
                                                @item.Title
                                            </div>
                                            <div class="small text-muted text-truncate"
                                                 style="max-width: 300px;">
                                                @item.Message
                                            </div>
                                        </td>

                                        <td>
                                            @item.NotificationType
                                        </td>

                                        <td>
                                            @item.Channel
                                        </td>

                                        <td>
                                            @(item.RecipientUserDisplay ?? "-")
                                        </td>

                                        <td>
                                            @(item.IsRead ? "Да" : "Не")
                                        </td>

                                        <td class="text-end">
                                            <div class="d-flex flex-wrap justify-content-end gap-2">
                                                <a asp-action="EditNotification"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteNotification"
                                                      asp-route-id="@item.Id"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()

                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-danger">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">
                        Няма записи.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
