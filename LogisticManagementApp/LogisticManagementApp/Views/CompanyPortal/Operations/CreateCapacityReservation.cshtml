@model LogisticManagementApp.Models.CompanyPortal.Operations.CapacityReservationCreateViewModel

@{
    ViewData["Title"] = "Нов capacity reservation";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов capacity reservation</h2>

                <form asp-action="CreateCapacityReservation" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="ResourceType" class="form-label"></label>
                            <select asp-for="ResourceType"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Operations.ResourceType>()"
                                    class="form-select">
                            </select>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="ResourceId" class="form-label"></label>
                            <select asp-for="ResourceId"
                                    asp-items="Model.ResourceOptions"
                                    class="form-select">
                                <option value="">Избери resource</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ShipmentId" class="form-label"></label>
                            <select asp-for="ShipmentId"
                                    asp-items="Model.ShipmentOptions"
                                    class="form-select">
                                <option value="">Без shipment</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ShipmentLegId" class="form-label"></label>
                            <select asp-for="ShipmentLegId"
                                    asp-items="Model.ShipmentLegOptions"
                                    class="form-select">
                                <option value="">Без shipment leg</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ReservedWeightKg" class="form-label"></label>
                            <input asp-for="ReservedWeightKg" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ReservedVolumeCbm" class="form-label"></label>
                            <input asp-for="ReservedVolumeCbm" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ReservedUnitCount" class="form-label"></label>
                            <input asp-for="ReservedUnitCount" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ReservedFromUtc" class="form-label"></label>
                            <input asp-for="ReservedFromUtc" type="datetime-local" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ReservedToUtc" class="form-label"></label>
                            <input asp-for="ReservedToUtc" type="datetime-local" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="CapacityReservations" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}