@model IEnumerable<LogisticManagementApp.Models.CompanyPortal.Operations.ResourceCalendarListItemViewModel>

@{
    ViewData["Title"] = "Resource Calendars";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-xl-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Resource Calendars</h2>
                        <p class="text-muted mb-0">
                            Календар и капацитет на ресурси.
                        </p>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Operations" class="btn btn-outline-light">
                            Към Operations
                        </a>

                        <a asp-action="CreateResourceCalendar" class="btn btn-primary">
                            Нов запис
                        </a>
                    </div>
                </div>

                @if (Model.Any())
                {
                    <div class="table-responsive" data-table-pagination-wrapper>
                        <table class="table align-middle"
                               data-table-pagination="true"
                               data-page-size="5">
                            <thead>
                                <tr>
                                    <th>Resource</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Planned</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">
                                                @item.ResourceDisplay
                                            </div>
                                            <div class="small text-muted">
                                                @item.ResourceType
                                            </div>
                                        </td>

                                        <td>
                                            @item.DateUtc.ToString("yyyy-MM-dd")
                                        </td>

                                        <td>
                                            @item.Status
                                        </td>

                                        <td>
                                            @(item.PlannedCapacity?.ToString("F2") ?? "-")
                                        </td>

                                        <td class="text-end">
                                            <div class="d-flex flex-wrap justify-content-end gap-2">
                                                <a asp-action="EditResourceCalendar"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-sm btn-outline-light">
                                                    Редакция
                                                </a>

                                                <form asp-action="DeleteResourceCalendar"
                                                      asp-route-id="@item.Id"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()

                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-danger">
                                                        Изтрий
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">
                        Няма записи.
                    </div>
                }
            </div>
        </div>
    </div>
</div>