@model LogisticManagementApp.Models.CompanyPortal.Operations.BookingLegCreateViewModel

@{
    ViewData["Title"] = "Нов booking leg";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов booking leg</h2>

                <form asp-action="CreateBookingLeg" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="BookingId" class="form-label"></label>
                            <select asp-for="BookingId"
                                    asp-items="Model.BookingOptions"
                                    class="form-select">
                                <option value="">Избери booking</option>
                            </select>
                            <span asp-validation-for="BookingId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ShipmentLegId" class="form-label"></label>
                            <select asp-for="ShipmentLegId"
                                    asp-items="Model.ShipmentLegOptions"
                                    class="form-select">
                                <option value="">Без shipment leg</option>
                            </select>
                            <span asp-validation-for="ShipmentLegId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="LegNo" class="form-label"></label>
                            <input asp-for="LegNo" class="form-control" />
                            <span asp-validation-for="LegNo" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="OriginLocationId" class="form-label"></label>
                            <select asp-for="OriginLocationId"
                                    asp-items="Model.LocationOptions"
                                    class="form-select">
                                <option value="">Без origin</option>
                            </select>
                            <span asp-validation-for="OriginLocationId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DestinationLocationId" class="form-label"></label>
                            <select asp-for="DestinationLocationId"
                                    asp-items="Model.LocationOptions"
                                    class="form-select">
                                <option value="">Без destination</option>
                            </select>
                            <span asp-validation-for="DestinationLocationId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ETD_Utc" class="form-label"></label>
                            <input asp-for="ETD_Utc" type="datetime-local" class="form-control" />
                            <span asp-validation-for="ETD_Utc" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ETA_Utc" class="form-label"></label>
                            <input asp-for="ETA_Utc" type="datetime-local" class="form-control" />
                            <span asp-validation-for="ETA_Utc" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CarrierReference" class="form-label"></label>
                            <input asp-for="CarrierReference" class="form-control" />
                            <span asp-validation-for="CarrierReference" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="BookingLegs" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}