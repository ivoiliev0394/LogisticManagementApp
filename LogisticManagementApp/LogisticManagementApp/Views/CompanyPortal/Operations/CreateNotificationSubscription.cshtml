@model LogisticManagementApp.Models.CompanyPortal.Operations.NotificationSubscriptionCreateViewModel

@{
    ViewData["Title"] = "Нов notification subscription";
}

<partial name="_CompanyModuleHeader" />

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <partial name="_CompanyNavigation" />
    </div>

    <div class="col-12 col-lg-9">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Нов notification subscription</h2>

                <form asp-action="CreateNotificationSubscription" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="UserId" class="form-label"></label>
                            <select asp-for="UserId"
                                    asp-items="Model.UserOptions"
                                    class="form-select">
                                <option value="">Ниво компания</option>
                            </select>
                            <span asp-validation-for="UserId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EventKey" class="form-label"></label>
                            <input asp-for="EventKey" class="form-control" />
                            <span asp-validation-for="EventKey" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Channel" class="form-label"></label>
                            <select asp-for="Channel"
                                    asp-items="Html.GetEnumSelectList<LogisticManagementApp.Domain.Enums.Operations.NotificationChannel>()"
                                    class="form-select">
                            </select>
                            <span asp-validation-for="Channel" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <div class="form-check mt-4 pt-2">
                                <input asp-for="IsEnabled" class="form-check-input" />
                                <span asp-validation-for="IsEnabled" class="text-danger"></span>
                                <label asp-for="IsEnabled" class="form-check-label">Активен</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" type="submit">Запази</button>
                        <a asp-action="NotificationSubscriptions" class="btn btn-outline-light">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}