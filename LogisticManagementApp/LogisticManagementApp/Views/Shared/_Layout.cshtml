<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LogisticManagementApp</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/LogisticManagementApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid">

                <!-- LOGO -->
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    🚛 LogisticApp
                </a>

                <!-- MOBILE -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">

                    <!-- LEFT -->
                    <ul class="navbar-nav me-auto align-items-center">

                        @if (User.Identity?.IsAuthenticated != true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">
                                    Tracking
                                </a>
                            </li>
                        }
                        else
                        {
                            @if (User.IsInRole("Client"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="ClientPortal" asp-action="Dashboard">
                                        ClientDashboard
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="ClientPortal" asp-action="MyOrders">Моите заявки</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="ClientPortal" asp-action="MyShipments">Моите пратки</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="ClientPortal" asp-action="MyAddresses">Моите адреси</a>
                                </li>
                            }
                        }

                    </ul>

                    <!-- RIGHT -->
                    <ul class="navbar-nav ms-auto align-items-center">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <!-- USER DROPDOWN -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle user-dropdown" href="#" role="button" data-bs-toggle="dropdown">
                                    👤 @User.Identity?.Name
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <span class="dropdown-item-text text-muted small">
                                            Logged in
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Home" asp-action="Index">
                                            Dashboard
                                        </a>
                                    </li>

                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">
                                                Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <!-- LOGIN -->
                            <li class="nav-item me-2">
                                <a class="btn btn-outline-success px-3"
                                       asp-controller="Auth"
                                       asp-action="Login">
                                    Login
                                </a>
                            </li>

                            <!-- REGISTER -->
                            <li class="nav-item">
                                <a class="btn btn-success px-3"
                                       asp-controller="Auth"
                                       asp-action="Register">
                                    Register
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <partial name="_StatusMessage" model="null" />

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - LogisticManagementApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <div class="modal fade" id="customDeleteConfirmModal" tabindex="-1" aria-labelledby="customDeleteConfirmModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content custom-confirm-modal">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <span class="badge bg-danger-subtle text-danger-emphasis mb-2">Потвърждение</span>
                        <h5 class="modal-title" id="customDeleteConfirmModalLabel">Потвърждение за изтриване</h5>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-3">
                    <p class="mb-0" id="customDeleteConfirmModalMessage">Сигурни ли сте, че искате да изтриете този запис?</p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Отказ</button>
                    <button type="button" class="btn btn-danger" id="customDeleteConfirmModalApprove">Да, изтрий</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/decimal-input-fix.js" asp-append-version="true"></script>
    <script src="~/js/auto-generated-fields.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>