@{
    var action = ViewContext.RouteData.Values["action"]?.ToString();

    string GetNavClass(params string[] actions)
    {
        return actions.Contains(action)
            ? "btn btn-success w-100 text-start"
            : "btn btn-outline-light w-100 text-start";
    }
}

