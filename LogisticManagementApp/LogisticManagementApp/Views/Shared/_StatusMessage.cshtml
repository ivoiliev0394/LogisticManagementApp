@model object
@{
    var modeledStatusMessage = Model is string s ? s : null;
    var successMessage = TempData["SuccessMessage"]?.ToString();
    var errorMessage = TempData["ErrorMessage"]?.ToString();
    var warningMessage = TempData["WarningMessage"]?.ToString();
    var infoMessage = TempData["InfoMessage"]?.ToString();

    var toastCssClass = string.Empty;
    var toastTitle = string.Empty;
    var toastIcon = string.Empty;
    var toastMessage = string.Empty;

    if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        toastCssClass = "app-toast-error";
        toastTitle = "Грешка";
        toastIcon = "!";
        toastMessage = errorMessage;
    }
    else if (!string.IsNullOrWhiteSpace(warningMessage))
    {
        toastCssClass = "app-toast-warning";
        toastTitle = "Внимание";
        toastIcon = "!";
        toastMessage = warningMessage;
    }
    else if (!string.IsNullOrWhiteSpace(successMessage))
    {
        toastCssClass = "app-toast-success";
        toastTitle = "Успешно";
        toastIcon = "✓";
        toastMessage = successMessage;
    }
    else if (!string.IsNullOrWhiteSpace(infoMessage))
    {
        toastCssClass = "app-toast-info";
        toastTitle = "Информация";
        toastIcon = "i";
        toastMessage = infoMessage;
    }
    else if (!string.IsNullOrWhiteSpace(modeledStatusMessage))
    {
        var normalized = modeledStatusMessage.Trim();
        var isError = normalized.StartsWith("Error", System.StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("Грешка", System.StringComparison.OrdinalIgnoreCase);

        toastCssClass = isError ? "app-toast-error" : "app-toast-success";
        toastTitle = isError ? "Грешка" : "Успешно";
        toastIcon = isError ? "!" : "✓";
        toastMessage = modeledStatusMessage;
    }
}

@if (!string.IsNullOrWhiteSpace(toastMessage))
{
    <div id="app-toast-stack" class="app-toast-stack">
        <div class="app-toast @toastCssClass" data-toast>
            <div class="app-toast-icon">@toastIcon</div>
            <div class="app-toast-content">
                <div class="app-toast-title">@toastTitle</div>
                <div class="app-toast-message">@toastMessage</div>
            </div>
            <button type="button" class="app-toast-close" data-toast-close aria-label="Close">×</button>
        </div>
    </div>

    <script>
        (function () {
            const toast = document.querySelector('[data-toast]');
            if (!toast) return;

            const closeBtn = toast.querySelector('[data-toast-close]');

            const removeToast = function () {
                if (!toast.isConnected) {
                    return;
                }

                toast.classList.add('app-toast-hide');

                setTimeout(function () {
                    toast.remove();
                }, 300);
            };

            if (closeBtn) {
                closeBtn.addEventListener('click', removeToast, { once: true });
            }

            setTimeout(removeToast, 4500);
        })();
    </script>
}
