@model LogisticManagementApp.Models.AdminPortal.AdminEntityDetailsViewModel
@{
    ViewData["Title"] = $"Admin · {Model.DisplayName}";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <div class="text-muted small">@Model.GroupName</div>
            <h1 class="h3 mb-0 d-flex align-items-center gap-2">
                <span>@Model.DisplayName</span>
                @if (Model.IsDeleted)
                {
                    <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle">Изтрит</span>
                }
            </h1>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Entities" asp-route-entity="@Model.EntityName" class="btn btn-outline-secondary">Назад</a>
            <a asp-action="Edit" asp-route-entity="@Model.EntityName" asp-route-key="@Model.Key" class="btn btn-primary">Редакция</a>
            @if (Model.CanDelete)
            {
                <a asp-action="Delete" asp-route-entity="@Model.EntityName" asp-route-key="@Model.Key" class="btn btn-danger">Изтриване</a>
            }
        </div>
    </div>
<div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0 text-muted">
                @foreach (var field in Model.Fields)
                {
                    <dt class="col-sm-4">@field.DisplayName</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(field.Value) ? "—" : field.Value)</dd>
                }
            </dl>
        </div>
    </div>
</div>
