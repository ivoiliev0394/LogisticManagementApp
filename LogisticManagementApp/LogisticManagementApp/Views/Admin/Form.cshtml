@model LogisticManagementApp.Models.AdminPortal.AdminEntityFormViewModel
@{
    ViewData["Title"] = Model.IsEdit ? $"Admin · Редакция {Model.DisplayName}" : $"Admin · Нов {Model.DisplayName}";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <div class="text-muted small">@Model.GroupName</div>
            <h1 class="h3 mb-0">@(Model.IsEdit ? $"Редакция на {Model.DisplayName}" : $"Нов {Model.DisplayName}")</h1>
        </div>
        <a asp-action="Entities" asp-route-entity="@Model.EntityName" class="btn btn-outline-secondary">Назад</a>
    </div>

    @await Html.PartialAsync("~/Views/Shared/_StatusMessage.cshtml")

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="@(Model.IsEdit ? "Edit" : "Create")" asp-route-entity="@Model.EntityName" asp-route-key="@Model.Key" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    @foreach (var field in Model.Fields)
                    {
                        if (field.IsKey && Model.IsEdit)
                        {
                            <input type="hidden" name="@field.Name" value="@field.Value" />
                            continue;
                        }

                        if (field.IsReadOnly && !Model.IsEdit)
                        {
                            continue;
                        }

                        <div class="col-12 col-md-6">
                            <label class="form-label" for="@field.Name">
                                @field.DisplayName
                                @if (field.IsKey)
                                {
                                    <span class="badge bg-secondary ms-1">PK</span>
                                }
                                @if (field.IsForeignKey)
                                {
                                    <span class="badge bg-info text-dark ms-1">FK</span>
                                }
                            </label>

                            @if (field.DataType == "checkbox")
                            {
                                <input type="hidden" name="@field.Name" value="false" />
                                <div class="form-check form-switch pt-2">
                                    <input class="form-check-input" type="checkbox" id="@field.Name" name="@field.Name" value="true" @(string.Equals(field.Value, "true", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                </div>
                            }
                            else if (field.DataType == "textarea")
                            {
                                <textarea class="form-control" id="@field.Name" name="@field.Name" rows="4">@field.Value</textarea>
                            }
                            else
                            {
                                <input class="form-control" type="@field.DataType" id="@field.Name" name="@field.Name" value="@field.Value" />
                            }
                        </div>
                    }
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success">Запази</button>
                    <a asp-action="Entities" asp-route-entity="@Model.EntityName" class="btn btn-outline-secondary">Отказ</a>
                </div>
            </form>
        </div>
    </div>
</div>
