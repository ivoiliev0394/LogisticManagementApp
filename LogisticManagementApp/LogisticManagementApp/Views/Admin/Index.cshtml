@model IReadOnlyList<LogisticManagementApp.Models.AdminPortal.AdminEntityGroupViewModel>
@{
    ViewData["Title"] = "Admin Portal";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Admin Portal</h1>
            <p class="text-muted mb-0">Пълен CRUD достъп до всички entity-та в системата.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Reports" class="btn btn-success">PDF Reports</a>
            <a asp-controller="Home" asp-action="AdminDashboard" class="btn btn-outline-secondary">Dashboard</a>
        </div>
    </div>
@foreach (var group in Model)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header admin-green-header border-0 pb-0">
                <h2 class="h5 mb-0">@group.Name</h2>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var entity in group.Entities)
                    {
                        <div class="col-12 col-md-6 col-xl-4">
                            <div class="border rounded-3 p-3 h-100">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-semibold text-muted">@entity.DisplayName</div>
                                        <div class="small text-muted">@entity.PropertyCount полета</div>
                                    </div>
                                    <a asp-action="Entities" asp-route-entity="@entity.Name" class="btn btn-sm btn-success">Отвори</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
