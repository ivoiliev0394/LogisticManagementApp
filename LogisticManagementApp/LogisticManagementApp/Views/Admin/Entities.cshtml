@model LogisticManagementApp.Models.AdminPortal.AdminEntityListViewModel
@{
    ViewData["Title"] = $"Admin · {Model.DisplayName}";
}

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <div class="text-muted small">@Model.GroupName</div>
            <h1 class="h3 mb-0">@Model.DisplayName</h1>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Всички entity-та</a>
            <a asp-action="EntityReport" asp-route-entity="@Model.EntityName" asp-route-searchTerm="@Model.SearchTerm" asp-route-filterColumn="@Model.FilterColumn" asp-route-filterValue="@Model.FilterValue" class="btn btn-outline-success">PDF Report</a>
            <a asp-action="Create" asp-route-entity="@Model.EntityName" class="btn btn-success">Нов запис</a>
        </div>
    </div>
<div class="card shadow-sm">
        <div class="card-body border-bottom">
            <form method="get" asp-action="Entities" class="row g-2 align-items-end">
                <input type="hidden" name="entity" value="@Model.EntityName" />

                <div class="col-12 col-lg-5">
                    <label class="form-label">Търсене</label>
                    <input type="text"
                           name="searchTerm"
                           value="@Model.SearchTerm"
                           class="form-control"
                           placeholder="Търси във всички колони..." />
                </div>

                <div class="col-12 col-lg-3">
                    <label class="form-label">Филтър колона</label>
                    <select name="filterColumn" class="form-select">
                        <option value="">Всички</option>
                        @foreach (var col in Model.Columns)
                        {
                            <option value="@col" selected="@(string.Equals(Model.FilterColumn, col, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@col</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-lg-3">
                    <label class="form-label">Стойност</label>
                    <input type="text"
                           name="filterValue"
                           value="@Model.FilterValue"
                           class="form-control"
                           placeholder="напр. Да, Sofia, Pending..." />
                </div>

                <div class="col-12 col-lg-1 d-grid">
                    <button type="submit" class="btn btn-primary">OK</button>
                </div>

                <div class="col-12">
                    <a asp-action="Entities" asp-route-entity="@Model.EntityName" class="btn btn-outline-secondary btn-sm">Изчисти</a>
                </div>
            </form>
        </div>
        <div class="table-responsive" data-table-pagination-wrapper>
            <table class="table table-hover align-middle mb-0" data-table-pagination="true" data-page-size="5" data-table-search="false">
                <thead class="table-light">
                    <tr>
                        @foreach (var col in Model.Columns)
                        {
                            <th>@col</th>
                        }
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr>
                            <td colspan="@(Model.Columns.Count + 1)" class="text-center text-muted py-4">Няма записи.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                @foreach (var col in Model.Columns)
                                {
                                    <td>@row.Values[col]</td>
                                }
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm gap-2">
                                        <a asp-action="Details" asp-route-entity="@Model.EntityName" asp-route-key="@row.Key" class="btn btn-outline-secondary">Details</a>
                                        <a asp-action="Edit" asp-route-entity="@Model.EntityName" asp-route-key="@row.Key" class="btn btn-outline-primary">Edit</a>
                                        @if (row.CanDelete)
                                        {
                                            <a asp-action="Delete" asp-route-entity="@Model.EntityName" asp-route-key="@row.Key" class="btn btn-outline-danger">Delete</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
