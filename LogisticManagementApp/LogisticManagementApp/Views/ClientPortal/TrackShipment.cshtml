@model LogisticManagementApp.Models.ClientPortal.ClientShipmentTrackingViewModel

@{
    ViewData["Title"] = "Проследяване на пратка";
}

<div class="container py-4">
    <h2 class="mb-4">Проследяване на пратка</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-body text-muted">
            <div class="row g-3">
                <div class="col-md-6">
                    <strong>Номер на пратка:</strong>
                    <div>@Model.ShipmentNo</div>
                </div>

                <div class="col-md-6">
                    <strong>Статус:</strong>
                    <div>@Model.Status</div>
                </div>

                <div class="col-md-6">
                    <strong>Текуща локация:</strong>
                    <div>@(string.IsNullOrWhiteSpace(Model.CurrentLocation) ? "Няма информация" : Model.CurrentLocation)</div>
                </div>

                <div class="col-md-6">
                    <strong>Последен update:</strong>
                    <div>@(string.IsNullOrWhiteSpace(Model.LastUpdate) ? "Няма информация" : Model.LastUpdate)</div>
                </div>

                <div class="col-12">
                    <strong>Бележки:</strong>
                    <div>@(string.IsNullOrWhiteSpace(Model.Notes) ? "Няма бележки" : Model.Notes)</div>
                </div>

                <div class="col-12">
                    <strong>Последни детайли:</strong>
                    <div>@(string.IsNullOrWhiteSpace(Model.Details) ? "Няма допълнителни детайли" : Model.Details)</div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="mb-3">История на пратката</h4>

    @if (Model.TrackingEvents != null && Model.TrackingEvents.Any())
    {
        <div class="card shadow-sm">
            <div class="table-responsive" data-table-pagination-wrapper>
                <table class="table table-striped table-hover mb-0" data-table-pagination="true" data-page-size="5">
                    <thead class="table-light">
                        <tr>
                            <th>Дата</th>
                            <th>Събитие</th>
                            <th>Локация</th>
                            <th>Детайли</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.TrackingEvents)
                        {
                            <tr>
                                <td>@item.EventTime</td>
                                <td>@item.EventType</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Location) ? "-" : item.Location)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Details) ? "-" : item.Details)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Все още няма tracking събития за тази пратка.
        </div>
    }

    <div class="mt-4">
        <a asp-controller="ClientPortal" asp-action="MyShipments" class="btn btn-outline-secondary">
            Назад към моите пратки
        </a>
    </div>
</div>